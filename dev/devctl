#!/usr/bin/env bash
# devctl — Development container controller for nightfall-photo-ingress.
#
# Nightfall deterministic model:
#   - Atomic bootstrap is the only valid init path (cmd_setup).
#   - No synthetic dependency installs; only npm ci from project lockfiles.
#   - Node version pinned via .node-version, installed in container via nvm.
#   - Both web stacks (webui/, metrics/dashboard/) are independent with shared
#     Node version and SvelteKit/Vite major consistency enforced at setup time.
#   - All stateful operations serialised via the global repo lock.
#   - DEVCTL_GLOBAL_LOCK_HELD=1 prevents reentry deadlock when called by
#     metricsctl or mcp_server.py while they already hold the lock.

# Strict mode and error handling.
set -euo pipefail

# Load common container helper functions and variables.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$PROJECT_ROOT/lib/container-common.sh"

# Container and profile configuration
CONTAINER="dev-photo-ingress"
PROFILE_DEFAULT="default"
PROFILE_DEV="staging"
SNAPSHOT_CLEAN="clean-installed"

# Configure container intnal paths
DEV_WEBUI_ROOT="/opt/nightfall-webui"
DEV_METRICS_DASHBOARD_ROOT="/opt/nightfall-metrics-dashboard"
DEV_VENV_ROOT="/opt/ingress"
DEV_WEBUI_PORT="${DEV_WEBUI_PORT:-5173}"
DEV_WEBUI_PROXY_DEVICE="dev-webui-proxy"

# Configure host cache paths (bind-mounted into the container for persistence and speed)
HOST_HOME="${HOME}"
HOST_CACHE_NPM_HOME="${HOST_HOME}/.npm"
HOST_CACHE_NPM="${HOST_HOME}/.cache/npm"
HOST_CACHE_PIP="${HOST_HOME}/.cache/pip"
HOST_CACHE_PLAYWRIGHT="${HOST_HOME}/.cache/ms-playwright"

# Global repo lock — shared with metricsctl and mcp_server.py
REPO_LOCK_FILE="/tmp/nightfall-repo.lock"
REPO_LOCK_FD=200
REPO_LOCK_TIMEOUT_SEC="${REPO_LOCK_TIMEOUT_SEC:-300}"

# Cache device names for lxc config; used in _ensure_cache_mounts and _print_cache_mounts.
CACHE_DEVICE_NPM_HOME="cache-root-npm-home"
CACHE_DEVICE_NPM="cache-root-cache-npm"
CACHE_DEVICE_PIP="cache-root-cache-pip"
CACHE_DEVICE_PLAYWRIGHT="cache-root-cache-playwright"

# Python bootstrap marker (idempotent; Python install is expensive and not
# invalidated by package-manifest changes).
MARKER_PYTHON="${DEV_VENV_ROOT}/.bootstrap-python.done"

# Logging helpers with consistent prefix and color coding.
_info() { nf_log_info "devctl" "$*"; }
_ok()   { nf_log_ok   "devctl" "$*"; }
_warn() { nf_log_warn "devctl" "$*"; }
_fail() { nf_log_fail "devctl" "$*"; }

# Compute a deterministic hash from package.json and package-lock.json.
# This is used to detect whether a stack's dependency manifest changed.
compute_manifest_hash() {
    local stack_dir="$1"
    local hash_file="$2"
    local pkg_json="$stack_dir/package.json"
    local lock_json="$stack_dir/package-lock.json"

    if [[ ! -f "$pkg_json" || ! -f "$lock_json" ]]; then
        echo "[devctl] Missing manifest files in $stack_dir" >&2
        return 1
    fi

    cat "$pkg_json" "$lock_json" | sha256sum | awk '{print $1}' > "$hash_file"
}

# Read a hash file and strip whitespace/newlines so comparisons are stable.
read_hash_file() {
    local path="$1"
    tr -d '[:space:]' < "$path"
}

# Compare host and container hash files and return success on exact match.
compare_manifest_hash() {
    local host_hash_file="$1"
    local container_hash_file="$2"

    local host_hash
    local container_hash
    host_hash="$(read_hash_file "$host_hash_file")"
    container_hash="$(read_hash_file "$container_hash_file")"
    [[ "$host_hash" == "$container_hash" ]]
}

# Acquire the global repo lock so stateful operations are serialized.
acquire_repo_lock() {
    exec {REPO_LOCK_FD}>"$REPO_LOCK_FILE"
    flock -w "$REPO_LOCK_TIMEOUT_SEC" "$REPO_LOCK_FD" || {
        echo "[devctl] Timed out waiting for global repo lock ($REPO_LOCK_FILE)" >&2
        exit 1
    }
}

# Release the global repo lock file descriptor if it is held.
release_repo_lock() {
    flock -u "$REPO_LOCK_FD"
    exec {REPO_LOCK_FD}>&-
}

# Read the project's pinned Node version from .nvmrc or .node-version.
# Returns the version without a leading "v".
get_node_version() {
    local raw=""
    if [[ -f "$PROJECT_ROOT/.nvmrc" ]]; then
        raw="$(tr -d '[:space:]' < "$PROJECT_ROOT/.nvmrc")"
    elif [[ -f "$PROJECT_ROOT/.node-version" ]]; then
        raw="$(tr -d '[:space:]' < "$PROJECT_ROOT/.node-version")"
    fi

    raw="${raw#v}"
    if [[ -n "$raw" ]]; then
        printf "%s" "$raw"
    fi
}

# Convert a semver range/value into just its major version number.
# Example: "^5.3.1" -> "5".
extract_major_from_semver() {
    local value="$1"
    value="${value#^}"
    value="${value#~}"
    value="${value#>=}"
    value="${value#>}"
    value="${value#<=}"
    value="${value#<}"
    value="${value%%.*}"
    value="${value%%-*}"
    printf "%s" "$value"
}

# Read a dependency version from the devDependencies section of package.json.
_json_dependency_version() {
    local package_file="$1"
    local dep_name="$2"
    python3 - <<'PY' "$package_file" "$dep_name"
import json
import sys
from pathlib import Path

pkg = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
dep = sys.argv[2]
dev_deps = pkg.get("devDependencies", {})
print(dev_deps.get(dep, ""))
PY
}

# Ensure web stacks stay aligned on SvelteKit and Vite major versions.
# This prevents subtle cross-stack tooling incompatibilities.
assert_web_stack_major_consistency() {
    local web_pkg="$PROJECT_ROOT/webui/package.json"
    local dashboard_pkg="$PROJECT_ROOT/metrics/dashboard/package.json"

    [[ -f "$web_pkg" ]] || { echo "Missing $web_pkg" >&2; return 1; }
    [[ -f "$dashboard_pkg" ]] || { echo "Missing $dashboard_pkg" >&2; return 1; }

    local web_kit web_vite dash_kit dash_vite
    web_kit="$(_json_dependency_version "$web_pkg" "@sveltejs/kit")"
    web_vite="$(_json_dependency_version "$web_pkg" "vite")"
    dash_kit="$(_json_dependency_version "$dashboard_pkg" "@sveltejs/kit")"
    dash_vite="$(_json_dependency_version "$dashboard_pkg" "vite")"

    local web_kit_major web_vite_major dash_kit_major dash_vite_major
    web_kit_major="$(extract_major_from_semver "$web_kit")"
    web_vite_major="$(extract_major_from_semver "$web_vite")"
    dash_kit_major="$(extract_major_from_semver "$dash_kit")"
    dash_vite_major="$(extract_major_from_semver "$dash_vite")"

    [[ -n "$web_kit_major" && -n "$web_vite_major" && -n "$dash_kit_major" && -n "$dash_vite_major" ]] || {
        echo "Unable to derive SvelteKit/Vite majors from package manifests" >&2
        return 1
    }

    [[ "$web_kit_major" == "$dash_kit_major" ]] || {
        echo "SvelteKit major mismatch: webui=$web_kit_major dashboard=$dash_kit_major" >&2
        return 1
    }

    [[ "$web_vite_major" == "$dash_vite_major" ]] || {
        echo "Vite major mismatch: webui=$web_vite_major dashboard=$dash_vite_major" >&2
        return 1
    }
}


# ── Lock management ───────────────────────────────────────────────────────────

_is_stateful_command() {
    local cmd="$1"
    case "$cmd" in
        setup|create|destroy|reset|snapshot-create|snapshot-refresh|\
        ensure-stack-ready|assert-cached-ready|\
        run-api|run-webui|\
        test-web-typecheck|test-metrics-dashboard-typecheck|\
        test-web-unit|test-web-e2e)
            return 0 ;;
        *) return 1 ;;
    esac
}

_acquire_command_lock() {
    local cmd="$1"
    _is_stateful_command "$cmd" || return 0
    # Reentry guard: metricsctl/mcp_server.py set this when they already hold
    # the lock and call devctl as a subprocess (e.g. ensure-stack-ready).
    if [[ "${DEVCTL_GLOBAL_LOCK_HELD:-}" == "1" ]]; then
        _info "Lock reentry detected (DEVCTL_GLOBAL_LOCK_HELD=1); skipping lock acquisition."
        return 0
    fi
    acquire_repo_lock
    _info "Acquired global repo lock: $REPO_LOCK_FILE"
}

# ── Container helpers ─────────────────────────────────────────────────────────

_wait_ready() {
    local i=0
    while ! lxc exec "$CONTAINER" -- systemctl is-system-running --quiet 2>/dev/null; do
        sleep 2
        i=$((i + 2))
        [[ $i -lt 40 ]] || _fail "Container did not become ready within 40 s."
    done
}

_has_snapshot_clean() {
    lxc info "$CONTAINER" 2>/dev/null | grep -Fq "| $SNAPSHOT_CLEAN |"
}

_ensure_cache_mounts() {
    mkdir -p "$HOST_CACHE_NPM_HOME" "$HOST_CACHE_NPM" "$HOST_CACHE_PIP" "$HOST_CACHE_PLAYWRIGHT"
    chmod 0777 "$HOST_CACHE_NPM_HOME" "$HOST_CACHE_NPM" "$HOST_CACHE_PIP" "$HOST_CACHE_PLAYWRIGHT" || true

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_NPM_HOME" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_NPM_HOME" disk \
        source="$HOST_CACHE_NPM_HOME" path="/root/.npm"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_NPM" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_NPM" disk \
        source="$HOST_CACHE_NPM" path="/root/.cache/npm"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_PIP" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_PIP" disk \
        source="$HOST_CACHE_PIP" path="/root/.cache/pip"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_PLAYWRIGHT" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_PLAYWRIGHT" disk \
        source="$HOST_CACHE_PLAYWRIGHT" path="/root/.cache/ms-playwright"
}

_print_cache_mounts() {
    cat <<MOUNTS
  $CACHE_DEVICE_NPM_HOME:   $HOST_CACHE_NPM_HOME -> /root/.npm
  $CACHE_DEVICE_NPM:        $HOST_CACHE_NPM -> /root/.cache/npm
  $CACHE_DEVICE_PIP:        $HOST_CACHE_PIP -> /root/.cache/pip
  $CACHE_DEVICE_PLAYWRIGHT: $HOST_CACHE_PLAYWRIGHT -> /root/.cache/ms-playwright
MOUNTS
}

_cache_mounts_active() {
    local devices
    devices="$(lxc config device show "$CONTAINER" 2>/dev/null || true)"
    grep -Fq "$CACHE_DEVICE_NPM_HOME:"  <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_NPM:"  <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_PIP:"  <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_PLAYWRIGHT:" <<<"$devices"
}

_refresh_clean_snapshot() {
    _info "Refreshing snapshot '$SNAPSHOT_CLEAN' ..."
    lxc delete "$CONTAINER/$SNAPSHOT_CLEAN" 2>/dev/null || true
    lxc snapshot "$CONTAINER" "$SNAPSHOT_CLEAN"
    _ok "Snapshot '$SNAPSHOT_CLEAN' refreshed."
}

_require_clean_snapshot() {
    _has_snapshot_clean || _fail "Snapshot '$SNAPSHOT_CLEAN' not found. Run: devctl snapshot-create"
}

# ── Source sync ───────────────────────────────────────────────────────────────

_sync_webui_sources() {
    lxc exec "$CONTAINER" -- mkdir -p "$DEV_WEBUI_ROOT"
    tar -C "$PROJECT_ROOT" \
        --exclude='webui/node_modules' \
        --exclude='webui/.svelte-kit' \
        --exclude='webui/build' \
        -czf - webui \
        | lxc exec "$CONTAINER" -- tar -xzf - -C "$DEV_WEBUI_ROOT" --strip-components=1
}

_sync_metrics_dashboard_sources() {
    lxc exec "$CONTAINER" -- mkdir -p "$DEV_METRICS_DASHBOARD_ROOT"
    tar -C "$PROJECT_ROOT" \
        --exclude='metrics/dashboard/node_modules' \
        --exclude='metrics/dashboard/.svelte-kit' \
        --exclude='metrics/dashboard/build' \
        -czf - metrics/dashboard \
        | lxc exec "$CONTAINER" -- tar -xzf - -C "$DEV_METRICS_DASHBOARD_ROOT" --strip-components=2
}

# ── Node version management ───────────────────────────────────────────────────

# Install the exact Node version from .node-version using nvm.
# Symlinks node/npm/npx to /usr/local/bin for non-login-shell access.
# Verifies exact version post-install; hard-fails on mismatch.
_install_node_exact() {
    local node_version="$1"
    _info "Installing Node.js $node_version in container via nvm ..."
    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
export NVM_DIR=/root/.nvm
if [[ ! -f \"\$NVM_DIR/nvm.sh\" ]]; then
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh \
        | PROFILE=/dev/null bash
fi
source \"\$NVM_DIR/nvm.sh\"
nvm install '$node_version'
nvm alias default '$node_version'
nvm use '$node_version'
# Symlink for non-login shells (lxc exec without -l)
node_bin_dir=\"\$(dirname \"\$(nvm which current)\")\"
ln -sf \"\$node_bin_dir/node\" /usr/local/bin/node
ln -sf \"\$node_bin_dir/npm\"  /usr/local/bin/npm
ln -sf \"\$node_bin_dir/npx\"  /usr/local/bin/npx
# Post-install verification — exact version required
actual=\"\$(node --version | tr -d 'v')\"
if [[ \"\$actual\" != '$node_version' ]]; then
    echo \"[devctl] Node install failed: required $node_version, got \$actual\" >&2
    exit 1
fi
echo \"[devctl] Node.js $node_version installed and verified.\""
    _ok "Node.js $node_version installed in container."
}

# Returns the node version string currently in the container (empty if absent).
_get_container_node_version() {
    # Uses /usr/local/bin/node symlink set by _install_node_exact; no nvm needed.
    lxc exec "$CONTAINER" -- bash -c \
        "node --version 2>/dev/null | tr -d 'v' || true" 2>/dev/null \
        | tr -d '[:space:]' || true
}

# Hard-fails if the container's Node version does not match the expected version.
_assert_node_matches_strict() {
    local expected="$1"
    local actual
    actual="$(_get_container_node_version)"
    if [[ "$actual" != "$expected" ]]; then
        _fail "Node version mismatch: required $expected, container has '${actual:-NONE}'. Run: devctl setup"
    fi
    _info "Node version verified: $actual"
}

# ── Stack install and drift detection ─────────────────────────────────────────

# Full install for one stack: sync full sources → rm node_modules/.svelte-kit
# → npm ci → write manifest hash.  Used by cmd_setup and Node-drift recovery.
_install_stack() {
    local stack="$1"
    local container_root container_hash_file
    if [[ "$stack" == "webui" ]]; then
        container_root="$DEV_WEBUI_ROOT"
        container_hash_file="/opt/nightfall-manifest/webui.hash"
        _sync_webui_sources
    else
        container_root="$DEV_METRICS_DASHBOARD_ROOT"
        container_hash_file="/opt/nightfall-manifest/dashboard.hash"
        _sync_metrics_dashboard_sources
    fi
    lxc exec "$CONTAINER" -- mkdir -p "$container_root" /opt/nightfall-manifest
    lxc exec "$CONTAINER" -- bash -c "
set -euo pipefail
cd '$container_root'
rm -rf node_modules .svelte-kit
npm ci
cat package.json package-lock.json | sha256sum | awk '{print \$1}' > '$container_hash_file'"
    _ok "$stack stack installed. Hash written."
}

# Drift detection for a single stack.
# MUST be called AFTER _sync_{webui,metrics_dashboard}_sources so the container
# holds the current host manifests before any npm ci runs.
# Reinstalls only if host manifest hash differs from the stored container hash.
_drift_check_stack() {
    local stack="$1"
    local stack_dir container_root container_hash_file host_hash container_hash
    if [[ "$stack" == "webui" ]]; then
        stack_dir="$PROJECT_ROOT/webui"
        container_root="$DEV_WEBUI_ROOT"
        container_hash_file="/opt/nightfall-manifest/webui.hash"
    else
        stack_dir="$PROJECT_ROOT/metrics/dashboard"
        container_root="$DEV_METRICS_DASHBOARD_ROOT"
        container_hash_file="/opt/nightfall-manifest/dashboard.hash"
    fi

    if [[ ! -f "$stack_dir/package.json" || ! -f "$stack_dir/package-lock.json" ]]; then
        _fail "$stack: missing package.json or package-lock.json in $stack_dir"
    fi

    host_hash="$(cat "$stack_dir/package.json" "$stack_dir/package-lock.json" \
        | sha256sum | awk '{print $1}')"
    container_hash="$(lxc exec "$CONTAINER" -- \
        bash -c "cat '$container_hash_file' 2>/dev/null | tr -d '[:space:]' || true")"

    if [[ "$host_hash" != "$container_hash" ]]; then
        _warn "$stack manifest drift (host=$host_hash container=${container_hash:-MISSING}). Reinstalling ..."
        lxc exec "$CONTAINER" -- mkdir -p /opt/nightfall-manifest
        lxc exec "$CONTAINER" -- bash -c "
set -euo pipefail
cd '$container_root'
rm -rf node_modules .svelte-kit
npm ci
cat package.json package-lock.json | sha256sum | awk '{print \$1}' > '$container_hash_file'"
        _ok "$stack stack reinstalled. Hash updated."
    else
        _ok "$stack stack up to date (hash=$host_hash)."
    fi
}

# Strict drift assertion — no remediation.  Hard-fails if drift remains.
# Used as a post-remediation gate before snapshot creation.
_assert_stack_no_drift() {
    local stack="$1"
    local stack_dir container_hash_file host_hash container_hash
    if [[ "$stack" == "webui" ]]; then
        stack_dir="$PROJECT_ROOT/webui"
        container_hash_file="/opt/nightfall-manifest/webui.hash"
    else
        stack_dir="$PROJECT_ROOT/metrics/dashboard"
        container_hash_file="/opt/nightfall-manifest/dashboard.hash"
    fi

    host_hash="$(cat "$stack_dir/package.json" "$stack_dir/package-lock.json" \
        | sha256sum | awk '{print $1}')"
    container_hash="$(lxc exec "$CONTAINER" -- \
        bash -c "cat '$container_hash_file' 2>/dev/null | tr -d '[:space:]' || true")"

    if [[ "$host_hash" != "$container_hash" ]]; then
        _fail "$stack drift remains after remediation (host=$host_hash container=${container_hash:-MISSING}). Run: devctl setup"
    fi
    _info "$stack no-drift verified: $host_hash"
}

# ── Stack readiness (entry point for all test/run commands) ───────────────────

# Ensures both or one stack is in sync with the host.
# Checks: SvelteKit/Vite major consistency (host) → Node version (container)
#         → source sync → manifest drift detection (per-stack).
# On Node drift: reinstalls both stacks unconditionally (native addons may be
# compiled for the old Node ABI).
_ensure_stack_ready() {
    local target="${1:-all}"
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"

    local node_version
    node_version="$(get_node_version)"
    [[ -n "$node_version" ]] || _fail "No .node-version file found in project root."

    # SvelteKit and Vite major versions must be consistent across both stacks.
    assert_web_stack_major_consistency

    # Node version drift check — ABI-level change requires reinstalling all stacks.
    local actual_node
    actual_node="$(_get_container_node_version)"
    if [[ "$actual_node" != "$node_version" ]]; then
        _warn "Node drift: required $node_version, container has '${actual_node:-NONE}'. Reinstalling Node + both stacks ..."
        _install_node_exact "$node_version"
        _install_stack webui
        _install_stack dashboard
        return 0
    fi

    # Per-stack drift detection; sources synced before drift check.
    if [[ "$target" == "webui" || "$target" == "all" ]]; then
        _sync_webui_sources
        _drift_check_stack webui
    fi
    if [[ "$target" == "dashboard" || "$target" == "all" ]]; then
        _sync_metrics_dashboard_sources
        _drift_check_stack dashboard
    fi
}

cmd_ensure_stack_ready() {
    local target="${1:-all}"
    case "$target" in
        webui|dashboard|all) ;;
        *) _fail "Usage: devctl ensure-stack-ready [webui|dashboard|all]" ;;
    esac
    _ensure_stack_ready "$target"
    _ok "Stack ready: $target"
}

# ── Python toolchain (private — called only from cmd_setup) ───────────────────

_bootstrap_python_toolchain() {
    if lxc exec "$CONTAINER" -- test -f "$MARKER_PYTHON" 2>/dev/null; then
        _ok "Python bootstrap already complete (marker present). Skipping."
        return 0
    fi
    _info "Installing Python toolchain in container ..."
    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
apt-get update -qq
apt-get install -y --no-install-recommends python3 python3-pip python3-venv
python3 -m venv '$DEV_VENV_ROOT'
'$DEV_VENV_ROOT'/bin/pip install --quiet --upgrade pip pytest pytest-asyncio httpx testcontainers
touch '$MARKER_PYTHON'"
    _ok "Python bootstrap completed in $DEV_VENV_ROOT."
}

# ── Container lifecycle commands ──────────────────────────────────────────────

cmd_create() {
    cmd_setup "$@"
}

cmd_setup() {
    # Atomic bootstrap: create container → cache mounts → exact Node (nvm) →
    # Python toolchain → webui stack (npm ci) → dashboard stack (npm ci) →
    # manifest hashes → clean snapshot.
    if lxc info "$CONTAINER" &>/dev/null; then
        _warn "Container '$CONTAINER' already exists. Ensuring cache mounts are configured."
    else
        _info "Launching container $CONTAINER (ubuntu:24.04, profiles: $PROFILE_DEFAULT+$PROFILE_DEV) ..."
        lxc launch ubuntu:24.04 "$CONTAINER" -p "$PROFILE_DEFAULT" -p "$PROFILE_DEV"
    fi

    _info "Configuring cache bind mounts ..."
    _ensure_cache_mounts

    if [[ "$(lxc list "$CONTAINER" -c s --format csv 2>/dev/null | tr -d '\r')" != "RUNNING" ]]; then
        _info "Starting container ..."
        lxc start "$CONTAINER"
    fi

    _info "Waiting for container readiness ..."
    _wait_ready

    # Validate SvelteKit/Vite major consistency across both stacks before install.
    assert_web_stack_major_consistency

    # Exact Node install via nvm — version sourced from .node-version.
    local node_version
    node_version="$(get_node_version)"
    [[ -n "$node_version" ]] || _fail "No .node-version file found in project root."
    _install_node_exact "$node_version"

    # Python toolchain (marker-based idempotency; not manifest-sensitive).
    _bootstrap_python_toolchain

    # Bootstrap both web stacks via npm ci (lockfile-only, no synthetic installs).
    _info "Bootstrapping webui stack ..."
    _install_stack webui

    _info "Bootstrapping metrics dashboard stack ..."
    _install_stack dashboard

    # Create the clean snapshot that reset/assert-cached-ready depend on.
    _refresh_clean_snapshot

    _ok "Atomic bootstrap complete."
    _info "Installed Node.js:       $node_version"
    _info "Webui hash:              $(lxc exec "$CONTAINER" -- cat /opt/nightfall-manifest/webui.hash)"
    _info "Dashboard hash:          $(lxc exec "$CONTAINER" -- cat /opt/nightfall-manifest/dashboard.hash)"
}

cmd_destroy() {
    _info "Deleting container $CONTAINER ..."
    lxc delete --force "$CONTAINER" 2>/dev/null || true
    _ok "Development container deleted."
}

cmd_reset() {
    nf_require_container_exists "$CONTAINER" "devctl setup" "devctl"
    _require_clean_snapshot

    _info "Stopping container ..."
    lxc stop "$CONTAINER" --force 2>/dev/null || true

    _info "Restoring snapshot '$SNAPSHOT_CLEAN' ..."
    lxc restore "$CONTAINER" "$SNAPSHOT_CLEAN"

    _info "Starting container ..."
    lxc start "$CONTAINER"
    _wait_ready

    _ok "Development container restored to '$SNAPSHOT_CLEAN'."
}

cmd_snapshot_create() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"

    local node_version
    node_version="$(get_node_version)"

    # Strict Node guard: snapshot must reflect the pinned version exactly.
    _assert_node_matches_strict "$node_version"

    # Sync sources then drift-check both stacks; reinstalls if manifests changed.
    _sync_webui_sources
    _drift_check_stack webui

    _sync_metrics_dashboard_sources
    _drift_check_stack dashboard

    # Post-remediation strict assertions: snapshot is only valid when
    # both stacks are verifiably drift-free.
    _assert_stack_no_drift webui
    _assert_stack_no_drift dashboard

    _refresh_clean_snapshot
}

cmd_snapshot_refresh() {
    cmd_snapshot_create
}

# ── Run commands ──────────────────────────────────────────────────────────────

cmd_run_webui() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui

    _info "Configuring host loopback proxy for Vite: 127.0.0.1:$DEV_WEBUI_PORT"
    lxc config device remove "$CONTAINER" "$DEV_WEBUI_PROXY_DEVICE" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$DEV_WEBUI_PROXY_DEVICE" proxy \
        listen="tcp:127.0.0.1:$DEV_WEBUI_PORT" \
        connect="tcp:127.0.0.1:$DEV_WEBUI_PORT"

    _ok "Dev web UI URL: http://127.0.0.1:$DEV_WEBUI_PORT/"
    _info "Starting Vite dev server in container (Ctrl+C to stop)."

    lxc exec -t "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
npx svelte-kit sync
npm run dev -- --host 0.0.0.0 --port '$DEV_WEBUI_PORT'"
}

cmd_run_api() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _warn "API run scaffold is not yet implemented. Use 'devctl shell' and run the API manually."
}

# ── Test commands ─────────────────────────────────────────────────────────────

cmd_test_web_unit() {
    if [[ -n "${DEVCTL_CONTRACT_TEST_ROOT:-}" ]]; then
        local web_root="$DEVCTL_CONTRACT_TEST_ROOT"
        local typecheck_runner="${DEVCTL_TEST_WEB_TYPECHECK_RUNNER:-npm exec -- svelte-check --fail-on-warnings}"
        local unit_runner="${DEVCTL_TEST_WEB_UNIT_RUNNER:-npx vitest run}"

        [[ -d "$web_root" ]] || _fail "Contract test root not found: $web_root"

        if [[ ! -d "$web_root/tests/component" ]]; then
            echo '[devctl] Missing tests/component directory in $DEV_WEBUI_ROOT' >&2
            return 1
        fi

        local count
        count="$(find "$web_root/tests/component" -type f \
            \( -name '*.test.ts' -o -name '*.test.js' \
               -o -name '*.spec.ts' -o -name '*.spec.js' \) \
            | wc -l | tr -d '[:space:]')"
        if [[ "$count" == "0" ]]; then
            echo '[devctl] No tests/component test files found' >&2
            return 1
        fi

        echo "[devctl] Discovered $count tests/component test file(s)."
        (cd "$web_root" && bash -lc "$typecheck_runner")
        (cd "$web_root" && bash -lc "$unit_runner")

        _ok "test-web-unit completed successfully."
        return 0
    fi

    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    # Sources synced + drift fixed inside _ensure_stack_ready.
    _ensure_stack_ready webui

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
    npx svelte-kit sync
if [[ ! -d tests/component ]]; then
    echo '[devctl] Missing tests/component directory in $DEV_WEBUI_ROOT' >&2
    exit 1
fi
count=\$(find tests/component -type f \
    \( -name '*.test.ts' -o -name '*.test.js' \
       -o -name '*.spec.ts' -o -name '*.spec.js' \) \
    | wc -l | tr -d '[:space:]')
if [[ \"\$count\" == \"0\" ]]; then
    echo '[devctl] No tests/component test files found' >&2
    exit 1
fi
echo \"[devctl] Discovered \$count tests/component test file(s).\"
npm exec -- svelte-check --fail-on-warnings
npx vitest run"

    _ok "test-web-unit completed successfully."
}

