#!/usr/bin/env bash
# devctl — Development container controller for nightfall-photo-ingress.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$PROJECT_ROOT/lib/container-common.sh"
source "$SCRIPT_DIR/devctl_helpers.sh"

CONTAINER="dev-photo-ingress"
PROFILE_DEFAULT="default"
PROFILE_DEV="staging"
SNAPSHOT_CLEAN="clean-installed"

DEV_WEBUI_ROOT="/opt/nightfall-webui"
DEV_METRICS_DASHBOARD_ROOT="/opt/nightfall-metrics-dashboard"
DEV_MANIFEST_DIR="/opt/nightfall-manifest"
DEV_VENV_ROOT="/opt/ingress"
DEV_WEBUI_PORT="${DEV_WEBUI_PORT:-5173}"
DEV_WEBUI_PROXY_DEVICE="dev-webui-proxy"

HOST_HOME="${HOME}"
HOST_CACHE_NPM_HOME="${HOST_HOME}/.npm"
HOST_CACHE_NPM="${HOST_HOME}/.cache/npm"
HOST_CACHE_PIP="${HOST_HOME}/.cache/pip"
HOST_CACHE_PLAYWRIGHT="${HOST_HOME}/.cache/ms-playwright"

CACHE_DEVICE_NPM_HOME="cache-root-npm-home"
CACHE_DEVICE_NPM="cache-root-cache-npm"
CACHE_DEVICE_PIP="cache-root-cache-pip"
CACHE_DEVICE_PLAYWRIGHT="cache-root-cache-playwright"

MARKER_PYTHON="${DEV_VENV_ROOT}/.bootstrap-python.done"

_info() { nf_log_info "devctl" "$*"; }
_ok() { nf_log_ok "devctl" "$*"; }
_warn() { nf_log_warn "devctl" "$*"; }
_fail() { nf_log_fail "devctl" "$*"; }

_is_stateful_command() {
    local cmd="$1"
    case "$cmd" in
        setup|create|destroy|reset|snapshot-create|snapshot-refresh|assert-cached-ready|run-api|run-webui|test-web-typecheck|test-metrics-dashboard-typecheck|test-web-unit|test-web-e2e|bootstrap-python|bootstrap-webui|bootstrap-playwright|ensure-stack-ready)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

_acquire_command_lock() {
    local cmd="$1"

    if ! _is_stateful_command "$cmd"; then
        return 0
    fi

    if [[ "${DEVCTL_GLOBAL_LOCK_HELD:-0}" == "1" ]]; then
        _info "Using existing global repo lock context."
        return 0
    fi

    acquire_repo_lock
    _info "Acquired global repo lock: $REPO_LOCK_FILE"
}

_wait_ready() {
    local i=0
    while ! lxc exec "$CONTAINER" -- systemctl is-system-running --quiet 2>/dev/null; do
        sleep 2
        i=$((i + 2))
        [[ $i -lt 40 ]] || _fail "Container did not become ready within 40 s."
    done
}

_has_snapshot_clean() {
    lxc info "$CONTAINER" 2>/dev/null | grep -Fq "| $SNAPSHOT_CLEAN |"
}

_ensure_cache_mounts() {
    mkdir -p "$HOST_CACHE_NPM_HOME" "$HOST_CACHE_NPM" "$HOST_CACHE_PIP" "$HOST_CACHE_PLAYWRIGHT"
    chmod 0777 "$HOST_CACHE_NPM_HOME" "$HOST_CACHE_NPM" "$HOST_CACHE_PIP" "$HOST_CACHE_PLAYWRIGHT" || true

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_NPM_HOME" >/dev/null 2>&1 || true
    lxc config device add "$CONTAINER" "$CACHE_DEVICE_NPM_HOME" disk source="$HOST_CACHE_NPM_HOME" path="/root/.npm"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_NPM" >/dev/null 2>&1 || true
    lxc config device add "$CONTAINER" "$CACHE_DEVICE_NPM" disk source="$HOST_CACHE_NPM" path="/root/.cache/npm"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_PIP" >/dev/null 2>&1 || true
    lxc config device add "$CONTAINER" "$CACHE_DEVICE_PIP" disk source="$HOST_CACHE_PIP" path="/root/.cache/pip"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_PLAYWRIGHT" >/dev/null 2>&1 || true
    lxc config device add "$CONTAINER" "$CACHE_DEVICE_PLAYWRIGHT" disk source="$HOST_CACHE_PLAYWRIGHT" path="/root/.cache/ms-playwright"
}

_print_cache_mounts() {
    cat <<MOUNTS
  $CACHE_DEVICE_NPM_HOME: $HOST_CACHE_NPM_HOME -> /root/.npm
  $CACHE_DEVICE_NPM: $HOST_CACHE_NPM -> /root/.cache/npm
  $CACHE_DEVICE_PIP: $HOST_CACHE_PIP -> /root/.cache/pip
  $CACHE_DEVICE_PLAYWRIGHT: $HOST_CACHE_PLAYWRIGHT -> /root/.cache/ms-playwright
MOUNTS
}

_cache_mounts_active() {
    local devices
    devices="$(lxc config device show "$CONTAINER" 2>/dev/null || true)"
    grep -Fq "$CACHE_DEVICE_NPM_HOME:" <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_NPM:" <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_PIP:" <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_PLAYWRIGHT:" <<<"$devices"
}

_refresh_clean_snapshot() {
    _info "Refreshing snapshot '$SNAPSHOT_CLEAN' ..."
    lxc delete "$CONTAINER/$SNAPSHOT_CLEAN" 2>/dev/null || true
    lxc snapshot "$CONTAINER" "$SNAPSHOT_CLEAN"
    _ok "Snapshot '$SNAPSHOT_CLEAN' refreshed."
}

_sync_webui_sources() {
    lxc exec "$CONTAINER" -- mkdir -p "$DEV_WEBUI_ROOT"
    tar -C "$PROJECT_ROOT" \
        --exclude='webui/node_modules' \
        --exclude='webui/.svelte-kit' \
        --exclude='webui/build' \
        -czf - webui \
        | lxc exec "$CONTAINER" -- tar -xzf - -C "$DEV_WEBUI_ROOT" --strip-components=1
}

_sync_dashboard_sources() {
    lxc exec "$CONTAINER" -- mkdir -p "$DEV_METRICS_DASHBOARD_ROOT"
    tar -C "$PROJECT_ROOT" \
        --exclude='metrics/dashboard/node_modules' \
        --exclude='metrics/dashboard/.svelte-kit' \
        --exclude='metrics/dashboard/build' \
        -czf - metrics/dashboard \
        | lxc exec "$CONTAINER" -- tar -xzf - -C "$DEV_METRICS_DASHBOARD_ROOT" --strip-components=2
}

_host_manifest_hash() {
    local stack="$1"
    local hash_file="$2"

    if [[ "$stack" == "webui" ]]; then
        compute_manifest_hash "$PROJECT_ROOT/webui" "$hash_file"
    else
        compute_manifest_hash "$PROJECT_ROOT/metrics/dashboard" "$hash_file"
    fi
}

_container_manifest_file() {
    local stack="$1"
    if [[ "$stack" == "webui" ]]; then
        printf "%s" "$DEV_MANIFEST_DIR/webui.hash"
    else
        printf "%s" "$DEV_MANIFEST_DIR/dashboard.hash"
    fi
}

_install_node_exact() {
    local node_version="$1"

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
apt-get update -qq
apt-get install -y --no-install-recommends curl ca-certificates
export NVM_DIR=/root/.nvm
if [[ ! -s \"\$NVM_DIR/nvm.sh\" ]]; then
  curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
fi
. \"\$NVM_DIR/nvm.sh\"
nvm install '$node_version'
nvm alias default '$node_version'
nvm use '$node_version'
ln -sf \"\$NVM_DIR/versions/node/v$node_version/bin/node\" /usr/local/bin/node
ln -sf \"\$NVM_DIR/versions/node/v$node_version/bin/npm\" /usr/local/bin/npm
ln -sf \"\$NVM_DIR/versions/node/v$node_version/bin/npx\" /usr/local/bin/npx
"

    local actual
    actual="$(lxc exec "$CONTAINER" -- node --version | tr -d 'v\r\n')"
    if [[ "$actual" != "$node_version" ]]; then
        _fail "Node version mismatch: required $node_version, got $actual"
    fi
}

_install_python_toolchain() {
    if lxc exec "$CONTAINER" -- test -f "$MARKER_PYTHON"; then
        _ok "Python toolchain already installed."
        return 0
    fi

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
apt-get update -qq
apt-get install -y --no-install-recommends python3 python3-pip python3-venv
python3 -m venv '$DEV_VENV_ROOT'
'$DEV_VENV_ROOT'/bin/pip install --quiet --upgrade pip pytest pytest-asyncio httpx testcontainers
touch '$MARKER_PYTHON'
"

    _ok "Python toolchain installed."
}

_install_stack() {
    local stack="$1"
    local stack_root
    local manifest_file

    if [[ "$stack" == "webui" ]]; then
        _sync_webui_sources
        stack_root="$DEV_WEBUI_ROOT"
    else
        _sync_dashboard_sources
        stack_root="$DEV_METRICS_DASHBOARD_ROOT"
    fi

    manifest_file="$(_container_manifest_file "$stack")"
    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
mkdir -p '$DEV_MANIFEST_DIR'
cd '$stack_root'
rm -rf node_modules .svelte-kit
npm ci
cat package.json package-lock.json | sha256sum | awk '{print \$1}' > '$manifest_file'
"
}

_assert_node_matches_or_fix() {
    local node_version="$1"
    local actual

    actual="$(lxc exec "$CONTAINER" -- node --version 2>/dev/null | tr -d 'v\r\n' || true)"
    if [[ "$actual" == "$node_version" ]]; then
        return 0
    fi

    _warn "Node drift detected (required=$node_version current=${actual:-missing}). Reinstalling both stacks."
    _install_node_exact "$node_version"
    _install_stack webui
    _install_stack dashboard
}

_assert_node_matches_strict() {
    local node_version="$1"
    local actual

    actual="$(lxc exec "$CONTAINER" -- node --version 2>/dev/null | tr -d 'v\r\n' || true)"
    [[ "$actual" == "$node_version" ]] || _fail "Node drift detected (required=$node_version current=${actual:-missing}). Snapshot creation blocked."
}

_drift_check_stack() {
    local stack="$1"
    local host_hash_file
    local container_manifest
    local container_hash

    host_hash_file="$(mktemp)"
    _host_manifest_hash "$stack" "$host_hash_file"

    container_manifest="$(_container_manifest_file "$stack")"
    container_hash="$(lxc exec "$CONTAINER" -- bash -lc "cat '$container_manifest' 2>/dev/null || true" | tr -d '[:space:]')"

    if [[ "$(read_hash_file "$host_hash_file")" != "$container_hash" ]]; then
        _warn "$stack manifest drift detected. Reinstalling only $stack stack."
        _install_stack "$stack"
        _ok "$stack stack reinstalled."
    else
        _ok "$stack stack is drift-free."
    fi

    rm -f "$host_hash_file"
}

_assert_stack_no_drift() {
    local stack="$1"
    local host_hash_file
    local container_manifest
    local container_hash

    host_hash_file="$(mktemp)"
    _host_manifest_hash "$stack" "$host_hash_file"

    container_manifest="$(_container_manifest_file "$stack")"
    container_hash="$(lxc exec "$CONTAINER" -- bash -lc "cat '$container_manifest' 2>/dev/null || true" | tr -d '[:space:]')"

    if [[ "$(read_hash_file "$host_hash_file")" != "$container_hash" ]]; then
        rm -f "$host_hash_file"
        _fail "$stack drift detected. Snapshot creation blocked. Run a stack-using command or 'devctl ensure-stack-ready $stack' first."
    fi

    rm -f "$host_hash_file"
}

_ensure_stack_ready() {
    local stack="$1"
    local node_version

    node_version="$(get_node_version)"
    [[ -n "$node_version" ]] || _fail "Missing .nvmrc or .node-version in project root."

    assert_web_stack_major_consistency || _fail "SvelteKit/Vite major mismatch across web stacks."

    _assert_node_matches_or_fix "$node_version"

    case "$stack" in
        webui)
            _drift_check_stack webui
            ;;
        dashboard)
            _drift_check_stack dashboard
            ;;
        all)
            _drift_check_stack webui
            _drift_check_stack dashboard
            ;;
        *)
            _fail "Unknown stack '$stack' (expected: webui|dashboard|all)"
            ;;
    esac
}

cmd_create() {
    cmd_setup "$@"
}

cmd_setup() {
    local node_version
    local web_hash dashboard_hash

    assert_web_stack_major_consistency || _fail "SvelteKit/Vite major mismatch across web stacks."

    node_version="$(get_node_version)"
    [[ -n "$node_version" ]] || _fail "Missing .nvmrc or .node-version in project root."

    if lxc info "$CONTAINER" &>/dev/null; then
        _warn "Container '$CONTAINER' already exists. Re-applying deterministic bootstrap."
    else
        _info "Launching container $CONTAINER (ubuntu:24.04, profiles: $PROFILE_DEFAULT+$PROFILE_DEV) ..."
        lxc launch ubuntu:24.04 "$CONTAINER" -p "$PROFILE_DEFAULT" -p "$PROFILE_DEV"
    fi

    _ensure_cache_mounts

    if [[ "$(lxc list "$CONTAINER" -c s --format csv 2>/dev/null | tr -d '\r')" != "RUNNING" ]]; then
        lxc start "$CONTAINER"
    fi
    _wait_ready

    _install_node_exact "$node_version"
    _install_python_toolchain
    _install_stack webui
    _install_stack dashboard

    _refresh_clean_snapshot

    web_hash="$(lxc exec "$CONTAINER" -- bash -lc "cat '$DEV_MANIFEST_DIR/webui.hash'")"
    dashboard_hash="$(lxc exec "$CONTAINER" -- bash -lc "cat '$DEV_MANIFEST_DIR/dashboard.hash'")"

    _ok "Atomic bootstrap complete."
    _info "Node version: $node_version"
    _info "webui.hash: $web_hash"
    _info "dashboard.hash: $dashboard_hash"
}

cmd_destroy() {
    _info "Deleting container $CONTAINER ..."
    lxc delete --force "$CONTAINER" 2>/dev/null || true
    _ok "Development container deleted."
}

cmd_reset() {
    nf_require_container_exists "$CONTAINER" "devctl setup" "devctl"
    _has_snapshot_clean || _fail "Snapshot '$SNAPSHOT_CLEAN' not found. Run: devctl setup or devctl snapshot-create"

    lxc stop "$CONTAINER" --force 2>/dev/null || true
    lxc restore "$CONTAINER" "$SNAPSHOT_CLEAN"
    lxc start "$CONTAINER"
    _wait_ready

    _ok "Container restored to '$SNAPSHOT_CLEAN'."
}

cmd_bootstrap_python() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _install_python_toolchain
}

cmd_bootstrap_webui() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui
}

cmd_bootstrap_playwright() {
    _warn "bootstrap-playwright is deprecated. Playwright deps must come from webui/package.json and are installed by npm ci only."
}

cmd_ensure_stack_ready() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    local stack="${1:-all}"
    _ensure_stack_ready "$stack"
}

cmd_snapshot_create() {
    local node_version

    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    node_version="$(get_node_version)"
    [[ -n "$node_version" ]] || _fail "Missing .nvmrc or .node-version in project root."

    _assert_node_matches_strict "$node_version"
    _assert_stack_no_drift webui
    _assert_stack_no_drift dashboard
    _refresh_clean_snapshot
}

cmd_snapshot_refresh() {
    cmd_snapshot_create "$@"
}

cmd_run_webui() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"

    _ensure_stack_ready webui
    _sync_webui_sources

    lxc config device remove "$CONTAINER" "$DEV_WEBUI_PROXY_DEVICE" >/dev/null 2>&1 || true
    lxc config device add "$CONTAINER" "$DEV_WEBUI_PROXY_DEVICE" proxy \
        listen="tcp:127.0.0.1:$DEV_WEBUI_PORT" \
        connect="tcp:127.0.0.1:$DEV_WEBUI_PORT"

    _ok "Dev web UI URL: http://127.0.0.1:$DEV_WEBUI_PORT/"

    lxc exec -t "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
npx svelte-kit sync
npm run dev -- --host 0.0.0.0 --port '$DEV_WEBUI_PORT'
"
}

cmd_run_api() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _warn "API run scaffold is not implemented yet."
}

cmd_test_web_typecheck() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui
    _sync_webui_sources

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
npm exec -- svelte-check --fail-on-warnings
"

    _ok "test-web-typecheck completed successfully."
}

cmd_test_web_unit() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui
    _sync_webui_sources

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
if [[ ! -d tests/component ]]; then
  echo '[devctl] Missing tests/component directory' >&2
  exit 1
fi
npm exec -- svelte-check --fail-on-warnings
npx vitest run
"

    _ok "test-web-unit completed successfully."
}

cmd_test_web_e2e() {
    local artifact_dir="${DEVCTL_E2E_ARTIFACT_DIR:-test-results/playwright}"

    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui
    _sync_webui_sources

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
if [[ ! -d tests/e2e ]]; then
  echo '[devctl] Missing tests/e2e directory' >&2
  exit 1
fi
mkdir -p '$artifact_dir'
echo 'E2E_ARTIFACT_PATH=$DEV_WEBUI_ROOT/$artifact_dir'
npx playwright test --reporter=line
"

    _ok "test-web-e2e completed successfully."
}

cmd_test_metrics_dashboard_typecheck() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready dashboard
    _sync_dashboard_sources

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_METRICS_DASHBOARD_ROOT'
npx svelte-kit sync
npm exec -- svelte-check --fail-on-warnings
"

    _ok "test-metrics-dashboard-typecheck completed successfully."
}

cmd_assert_cached_ready() {
    nf_require_container_exists "$CONTAINER" "devctl setup" "devctl"

    _cache_mounts_active || _fail "Cache mounts are incomplete. Run: devctl setup"
    _has_snapshot_clean || _fail "Snapshot '$SNAPSHOT_CLEAN' missing. Run: devctl setup or devctl snapshot-create"

    _ok "Cache mounts and clean snapshot are ready."
}

cmd_status() {
    if lxc info "$CONTAINER" &>/dev/null; then
        lxc info "$CONTAINER"
        _has_snapshot_clean && _ok "Snapshot '$SNAPSHOT_CLEAN' present" || _warn "Snapshot '$SNAPSHOT_CLEAN' missing"
        _cache_mounts_active && _ok "Cache mounts: active" || _warn "Cache mounts: incomplete"
        _print_cache_mounts
    else
        _warn "Container '$CONTAINER' does not exist."
    fi
}

cmd_shell() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    lxc exec -t "$CONTAINER" -- bash
}

_usage() {
    cat <<USAGE
Usage: $(basename "$0") <command>

Commands:
  setup               Create/start container and run atomic bootstrap.
  create              Alias for setup.
  destroy             Delete development container.
  reset               Restore from snapshot '$SNAPSHOT_CLEAN'.
  snapshot-create     Create/update '$SNAPSHOT_CLEAN' only if no drift is detected.
  snapshot-refresh    Alias for snapshot-create.
  bootstrap-python    Install Python toolchain in container.
  bootstrap-webui     Ensure webui stack is installed and drift-free.
  bootstrap-playwright Deprecated (playwright deps come from npm ci only).
  ensure-stack-ready  Drift-check/reinstall stack: webui|dashboard|all (default: all).
  assert-cached-ready Ensure cache mounts and clean snapshot are available.
  run-api             API run scaffold (placeholder).
  run-webui           Drift-check webui, sync sources, run Vite in container.
  test-web-typecheck  Drift-check webui, then run svelte-check in container.
  test-metrics-dashboard-typecheck Drift-check dashboard, then run svelte-check in container.
  test-web-unit       Drift-check webui, then run Vitest in container.
  test-web-e2e        Drift-check webui, then run Playwright in container.
  status              Show container, snapshot, and cache mount status.
  shell               Open interactive shell in container.

Environment variables:
  DEV_WEBUI_PORT      Port for webui Vite server (default: 5173).
USAGE
    exit 1
}

main() {
    local cmd="${1:-}"
    shift || true

    _acquire_command_lock "$cmd"

    case "$cmd" in
        setup) cmd_setup "$@" ;;
        create) cmd_create "$@" ;;
        destroy) cmd_destroy "$@" ;;
        reset) cmd_reset "$@" ;;
        snapshot-create) cmd_snapshot_create "$@" ;;
        snapshot-refresh) cmd_snapshot_refresh "$@" ;;
        bootstrap-python) cmd_bootstrap_python "$@" ;;
        bootstrap-webui) cmd_bootstrap_webui "$@" ;;
        bootstrap-playwright) cmd_bootstrap_playwright "$@" ;;
        ensure-stack-ready) cmd_ensure_stack_ready "$@" ;;
        assert-cached-ready) cmd_assert_cached_ready "$@" ;;
        run-api) cmd_run_api "$@" ;;
        run-webui) cmd_run_webui "$@" ;;
        test-web-typecheck) cmd_test_web_typecheck "$@" ;;
        test-metrics-dashboard-typecheck) cmd_test_metrics_dashboard_typecheck "$@" ;;
        test-web-unit) cmd_test_web_unit "$@" ;;
        test-web-e2e) cmd_test_web_e2e "$@" ;;
        status) cmd_status "$@" ;;
        shell) cmd_shell "$@" ;;
        *) _usage ;;
    esac
}

main "$@"
