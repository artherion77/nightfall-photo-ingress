    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
if [[ ! -d tests/e2e ]]; then
        echo '[devctl] WARN: tests/e2e directory missing; skipping E2E run.'
        exit 0
fi
count=\$(find tests/e2e -type f \
    \( -name '*.spec.ts' -o -name '*.spec.js' \) \
    | wc -l | tr -d '[:space:]')
if [[ \"\$count\" == \"0\" ]]; then
        echo '[devctl] WARN: No tests/e2e spec files found; skipping E2E run.'
        exit 0
fi
echo \"[devctl] Discovered \$count tests/e2e spec file(s).\"
