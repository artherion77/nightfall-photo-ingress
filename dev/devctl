cmd_test_web_e2e() {
    local artifact_dir="${DEVCTL_E2E_ARTIFACT_DIR:-test-results/playwright}"

    if [[ -n "${DEVCTL_CONTRACT_TEST_ROOT:-}" ]]; then
        local web_root="$DEVCTL_CONTRACT_TEST_ROOT"
        local e2e_runner="${DEVCTL_TEST_WEB_E2E_RUNNER:-npx playwright test --reporter=line}"

        [[ -d "$web_root" ]] || _fail "Contract test root not found: $web_root"

        if [[ ! -d "$web_root/tests/e2e" ]]; then
            echo '[devctl] WARN: tests/e2e directory missing; skipping E2E run.'
            _ok "test-web-e2e completed successfully (or skipped when no e2e specs exist)."
            return 0
        fi

        local count
        count="$(find "$web_root/tests/e2e" -type f \
            \( -name '*.spec.ts' -o -name '*.spec.js' \) \
            | wc -l | tr -d '[:space:]')"
        if [[ "$count" == "0" ]]; then
            echo '[devctl] WARN: No tests/e2e spec files found; skipping E2E run.'
            _ok "test-web-e2e completed successfully (or skipped when no e2e specs exist)."
            return 0
        fi

        echo "[devctl] Discovered $count tests/e2e spec file(s)."
        mkdir -p "$web_root/$artifact_dir"
        echo "E2E_ARTIFACT_PATH=$web_root/$artifact_dir"
        (cd "$web_root" && bash -lc "$e2e_runner")

        _ok "test-web-e2e completed successfully."
        return 0
    fi

    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
