npx playwright test --reporter=line"

    _ok "test-web-e2e completed successfully (or skipped when no e2e specs exist)."
}

# ── Status / utility commands ─────────────────────────────────────────────────

cmd_assert_cached_ready() {
    nf_require_container_exists "$CONTAINER" "devctl setup" "devctl"

    _cache_mounts_active \
        || _fail "Cache mounts not fully configured. Run: devctl setup"

    _has_snapshot_clean \
        || _fail "Clean snapshot '$SNAPSHOT_CLEAN' missing. Run: devctl snapshot-create"

    _ok "Cache mounts and clean snapshot are ready."
}

cmd_status() {
    if lxc info "$CONTAINER" &>/dev/null; then
        lxc info "$CONTAINER"
        if _has_snapshot_clean; then
            _ok  "Snapshot status: '$SNAPSHOT_CLEAN' present"
        else
            _warn "Snapshot status: '$SNAPSHOT_CLEAN' missing"
        fi
        if _cache_mounts_active; then
            _ok  "Cache mounts: active"
        else
            _warn "Cache mounts: incomplete"
        fi
        _info "Configured cache mounts:"
        _print_cache_mounts
    else
        _warn "Container '$CONTAINER' does not exist."
    fi
}

cmd_shell() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    lxc exec -t "$CONTAINER" -- bash
}

_usage() {
    cat <<USAGE
Usage: $(basename "$0") <command>

Commands:
  setup                             Atomic bootstrap: create/start container, install exact Node
                                    (nvm), Python toolchain, both web stacks (npm ci), snapshot.
  create                            Alias for setup.
  destroy                           Delete development container.
  reset                             Restore development container from snapshot '$SNAPSHOT_CLEAN'.
  snapshot-create                   Create/update snapshot; enforces Node + drift-free invariants.
  snapshot-refresh                  Alias for snapshot-create.
  ensure-stack-ready [target]       Sync sources and drift-check; target: webui|dashboard|all.
  assert-cached-ready               Verify cache mounts and clean snapshot are present.
  run-api                           API run scaffold (not yet implemented).
  run-webui                         Sync webui sources and start Vite dev server.
  test-web-typecheck                Run webui Svelte/TypeScript typecheck.
  test-metrics-dashboard-typecheck  Run metrics dashboard Svelte/TypeScript typecheck.
  test-web-unit                     Run Vitest unit/component tests.
  test-web-e2e                      Run Playwright e2e browser tests.
  status                            Show container, snapshot, and cache mount status.
  shell                             Open interactive shell in development container.

Environment variables:
  DEV_WEBUI_PORT            Vite dev server port (default: 5173).
  DEVCTL_E2E_ARTIFACT_DIR   Playwright artifact directory (default: test-results/playwright).
  DEVCTL_GLOBAL_LOCK_HELD   Set to 1 by callers that already hold the global repo lock.
  REPO_LOCK_TIMEOUT_SEC     Global repo lock wait timeout in seconds (default: 300).
    DEVCTL_CONTRACT_TEST_ROOT Contract-test mode root path (host execution; bypasses container).
    DEVCTL_TEST_WEB_TYPECHECK_RUNNER
                                                        Contract-test override for web typecheck command (default: npm exec -- svelte-check --fail-on-warnings).
    DEVCTL_TEST_WEB_UNIT_RUNNER
                                                        Contract-test override for web unit test command (default: npx vitest run).
    DEVCTL_TEST_WEB_E2E_RUNNER
                                                        Contract-test override for web e2e command (default: npx playwright test --reporter=line).

Notes:
    Contract-test overrides are intended for unit/contract harnesses only.
    When DEVCTL_CONTRACT_TEST_ROOT is set, web test commands run on the host
    against that path and do not require container dependencies.
USAGE
    exit 1
}

main() {
    local cmd="${1:-}"
    shift || true

    _acquire_command_lock "$cmd"

    case "$cmd" in
        setup)                            cmd_setup "$@" ;;
        create)                           cmd_create "$@" ;;
        destroy)                          cmd_destroy "$@" ;;
        reset)                            cmd_reset "$@" ;;
        snapshot-create)                  cmd_snapshot_create "$@" ;;
        snapshot-refresh)                 cmd_snapshot_refresh "$@" ;;
        ensure-stack-ready)               cmd_ensure_stack_ready "$@" ;;
        assert-cached-ready)              cmd_assert_cached_ready "$@" ;;
        run-api)                          cmd_run_api "$@" ;;
        run-webui)                        cmd_run_webui "$@" ;;
        test-web-typecheck)               cmd_test_web_typecheck "$@" ;;
        test-metrics-dashboard-typecheck) cmd_test_metrics_dashboard_typecheck "$@" ;;
        test-web-unit)                    cmd_test_web_unit "$@" ;;
        test-web-e2e)                     cmd_test_web_e2e "$@" ;;
        status)                           cmd_status "$@" ;;
        shell)                            cmd_shell "$@" ;;
        *)                                _usage ;;
    esac
}

main "$@"
