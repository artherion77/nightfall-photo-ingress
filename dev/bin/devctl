#!/usr/bin/env bash
# devctl — Development container controller for nightfall-photo-ingress.
#
# Nightfall deterministic model:
#   - Atomic bootstrap is the only valid init path (cmd_setup).
#   - No synthetic dependency installs; only npm ci from project lockfiles.
#   - Node version pinned via .node-version, installed in container via nvm.
#   - Both web stacks (webui/, metrics/dashboard/) are independent with shared
#     Node version and SvelteKit/Vite major consistency enforced at setup time.
#   - All stateful operations serialised via the global repo lock.
#   - DEVCTL_GLOBAL_LOCK_HELD=1 prevents reentry deadlock when called by
#     metricsctl or mcp_server.py while they already hold the lock.

# Strict mode and error handling.
set -euo pipefail

# Load common container helper functions and variables.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$PROJECT_ROOT/lib/container-common.sh"

# Container and profile configuration
CONTAINER="dev-photo-ingress"
PROFILE_DEFAULT="default"
PROFILE_DEV="staging"
SNAPSHOT_BASE="base"
SNAPSHOT_CURRENT="current"

# Configure container intnal paths
DEV_WEBUI_ROOT="/opt/nightfall-webui"
DEV_METRICS_DASHBOARD_ROOT="/opt/nightfall-metrics-dashboard"
DEV_VENV_ROOT="/opt/ingress"
DEV_WEBUI_PORT="${DEV_WEBUI_PORT:-5173}"
DEV_WEBUI_PROXY_DEVICE="dev-webui-proxy"

# Configure host cache paths (bind-mounted into the container for persistence and speed)
HOST_HOME="${HOME}"
HOST_CACHE_NPM_HOME="${HOST_HOME}/.npm"
HOST_CACHE_NPM="${HOST_HOME}/.cache/npm"
HOST_CACHE_PIP="${HOST_HOME}/.cache/pip"
HOST_CACHE_PLAYWRIGHT="${HOST_HOME}/.cache/ms-playwright"

# Global repo lock — shared with metricsctl and mcp_server.py
REPO_LOCK_FILE="/tmp/nightfall-repo.lock"
REPO_LOCK_FD=200
REPO_LOCK_TIMEOUT_SEC="${REPO_LOCK_TIMEOUT_SEC:-300}"

# Cache device names for lxc config; used in _ensure_cache_mounts and _print_cache_mounts.
CACHE_DEVICE_NPM_HOME="cache-root-npm-home"
CACHE_DEVICE_NPM="cache-root-cache-npm"
CACHE_DEVICE_PIP="cache-root-cache-pip"
CACHE_DEVICE_PLAYWRIGHT="cache-root-cache-playwright"

# Python bootstrap marker (idempotent; Python install is expensive and not
# invalidated by package-manifest changes).
MARKER_PYTHON="${DEV_VENV_ROOT}/.bootstrap-python.done"

# Logging helpers with consistent prefix and color coding.
_info() { nf_log_info "devctl" "$*"; }
_ok()   { nf_log_ok   "devctl" "$*"; }
_warn() { nf_log_warn "devctl" "$*"; }
_fail() { nf_log_fail "devctl" "$*"; }

# Compute a deterministic hash from package.json and package-lock.json.
# This is used to detect whether a stack's dependency manifest changed.
compute_manifest_hash() {
    local stack_dir="$1"
    local hash_file="$2"
    local pkg_json="$stack_dir/package.json"
    local lock_json="$stack_dir/package-lock.json"

    if [[ ! -f "$pkg_json" || ! -f "$lock_json" ]]; then
        echo "[devctl] Missing manifest files in $stack_dir" >&2
        return 1
    fi

    cat "$pkg_json" "$lock_json" | sha256sum | awk '{print $1}' > "$hash_file"
}

# Read a hash file and strip whitespace/newlines so comparisons are stable.
read_hash_file() {
    local path="$1"
    tr -d '[:space:]' < "$path"
}

# Compare host and container hash files and return success on exact match.
compare_manifest_hash() {
    local host_hash_file="$1"
    local container_hash_file="$2"

    local host_hash
    local container_hash
    host_hash="$(read_hash_file "$host_hash_file")"
    container_hash="$(read_hash_file "$container_hash_file")"
    [[ "$host_hash" == "$container_hash" ]]
}

# Acquire the global repo lock so stateful operations are serialized.
acquire_repo_lock() {
    exec {REPO_LOCK_FD}>"$REPO_LOCK_FILE"
    flock -w "$REPO_LOCK_TIMEOUT_SEC" "$REPO_LOCK_FD" || {
        echo "[devctl] Timed out waiting for global repo lock ($REPO_LOCK_FILE)" >&2
        exit 1
    }
}

# Release the global repo lock file descriptor if it is held.
release_repo_lock() {
    flock -u "$REPO_LOCK_FD"
    exec {REPO_LOCK_FD}>&-
}

# Read the project's pinned Node version from .nvmrc or .node-version.
# Returns the version without a leading "v".
get_node_version() {
    local raw=""
    if [[ -f "$PROJECT_ROOT/.nvmrc" ]]; then
        raw="$(tr -d '[:space:]' < "$PROJECT_ROOT/.nvmrc")"
    elif [[ -f "$PROJECT_ROOT/.node-version" ]]; then
        raw="$(tr -d '[:space:]' < "$PROJECT_ROOT/.node-version")"
    fi

    raw="${raw#v}"
    if [[ -n "$raw" ]]; then
        printf "%s" "$raw"
    fi
}

# Convert a semver range/value into just its major version number.
# Example: "^5.3.1" -> "5".
extract_major_from_semver() {
    local value="$1"
    value="${value#^}"
    value="${value#~}"
    value="${value#>=}"
    value="${value#>}"
    value="${value#<=}"
    value="${value#<}"
    value="${value%%.*}"
    value="${value%%-*}"
    printf "%s" "$value"
}

# Read a dependency version from the devDependencies section of package.json.
_json_dependency_version() {
    local package_file="$1"
    local dep_name="$2"
    python3 - <<'PY' "$package_file" "$dep_name"
import json
import sys
from pathlib import Path

pkg = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
dep = sys.argv[2]
dev_deps = pkg.get("devDependencies", {})
print(dev_deps.get(dep, ""))
PY
}

# Ensure web stacks stay aligned on SvelteKit and Vite major versions.
# This prevents subtle cross-stack tooling incompatibilities.
assert_web_stack_major_consistency() {
    local web_pkg="$PROJECT_ROOT/webui/package.json"
    local dashboard_pkg="$PROJECT_ROOT/metrics/dashboard/package.json"

    [[ -f "$web_pkg" ]] || { echo "Missing $web_pkg" >&2; return 1; }
    [[ -f "$dashboard_pkg" ]] || { echo "Missing $dashboard_pkg" >&2; return 1; }

    local web_kit web_vite dash_kit dash_vite
    web_kit="$(_json_dependency_version "$web_pkg" "@sveltejs/kit")"
    web_vite="$(_json_dependency_version "$web_pkg" "vite")"
    dash_kit="$(_json_dependency_version "$dashboard_pkg" "@sveltejs/kit")"
    dash_vite="$(_json_dependency_version "$dashboard_pkg" "vite")"

    local web_kit_major web_vite_major dash_kit_major dash_vite_major
    web_kit_major="$(extract_major_from_semver "$web_kit")"
    web_vite_major="$(extract_major_from_semver "$web_vite")"
    dash_kit_major="$(extract_major_from_semver "$dash_kit")"
    dash_vite_major="$(extract_major_from_semver "$dash_vite")"

    [[ -n "$web_kit_major" && -n "$web_vite_major" && -n "$dash_kit_major" && -n "$dash_vite_major" ]] || {
        echo "Unable to derive SvelteKit/Vite majors from package manifests" >&2
        return 1
    }

    [[ "$web_kit_major" == "$dash_kit_major" ]] || {
        echo "SvelteKit major mismatch: webui=$web_kit_major dashboard=$dash_kit_major" >&2
        return 1
    }

    [[ "$web_vite_major" == "$dash_vite_major" ]] || {
        echo "Vite major mismatch: webui=$web_vite_major dashboard=$dash_vite_major" >&2
        return 1
    }
}


# ── Lock management ───────────────────────────────────────────────────────────

_is_stateful_command() {
    local cmd="$1"
    case "$cmd" in
        setup|destroy|reset|update|\
        ensure-stack-ready|assert-cached-ready|\
        run-api|run-webui|\
        test-web-typecheck|test-metrics-dashboard-typecheck|\
        test-web-unit|test-web-e2e)
            return 0 ;;
        *) return 1 ;;
    esac
}

_acquire_command_lock() {
    local cmd="$1"
    _is_stateful_command "$cmd" || return 0
    # Reentry guard: metricsctl/mcp_server.py set this when they already hold
    # the lock and call devctl as a subprocess (e.g. ensure-stack-ready).
    if [[ "${DEVCTL_GLOBAL_LOCK_HELD:-}" == "1" ]]; then
        _info "Lock reentry detected (DEVCTL_GLOBAL_LOCK_HELD=1); skipping lock acquisition."
        return 0
    fi
    acquire_repo_lock
    _info "Acquired global repo lock: $REPO_LOCK_FILE"
}

# ── Container helpers ─────────────────────────────────────────────────────────

_wait_ready() {
    local i=0
    while ! lxc exec "$CONTAINER" -- systemctl is-system-running --quiet 2>/dev/null; do
        sleep 2
        i=$((i + 2))
        [[ $i -lt 40 ]] || _fail "Container did not become ready within 40 s."
    done
}

_has_snapshot_base() {
    lxc info "$CONTAINER" 2>/dev/null | grep -Eq "\|[[:space:]]*$SNAPSHOT_BASE[[:space:]]*\|"
}

_has_snapshot_current() {
    lxc info "$CONTAINER" 2>/dev/null | grep -Eq "\|[[:space:]]*$SNAPSHOT_CURRENT[[:space:]]*\|"
}

_ensure_cache_mounts() {
    mkdir -p "$HOST_CACHE_NPM_HOME" "$HOST_CACHE_NPM" "$HOST_CACHE_PIP" "$HOST_CACHE_PLAYWRIGHT"
    chmod 0777 "$HOST_CACHE_NPM_HOME" "$HOST_CACHE_NPM" "$HOST_CACHE_PIP" "$HOST_CACHE_PLAYWRIGHT" || true

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_NPM_HOME" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_NPM_HOME" disk \
        source="$HOST_CACHE_NPM_HOME" path="/root/.npm"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_NPM" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_NPM" disk \
        source="$HOST_CACHE_NPM" path="/root/.cache/npm"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_PIP" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_PIP" disk \
        source="$HOST_CACHE_PIP" path="/root/.cache/pip"

    lxc config device remove "$CONTAINER" "$CACHE_DEVICE_PLAYWRIGHT" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$CACHE_DEVICE_PLAYWRIGHT" disk \
        source="$HOST_CACHE_PLAYWRIGHT" path="/root/.cache/ms-playwright"
}

_print_cache_mounts() {
    cat <<MOUNTS
  $CACHE_DEVICE_NPM_HOME:   $HOST_CACHE_NPM_HOME -> /root/.npm
  $CACHE_DEVICE_NPM:        $HOST_CACHE_NPM -> /root/.cache/npm
  $CACHE_DEVICE_PIP:        $HOST_CACHE_PIP -> /root/.cache/pip
  $CACHE_DEVICE_PLAYWRIGHT: $HOST_CACHE_PLAYWRIGHT -> /root/.cache/ms-playwright
MOUNTS
}

_cache_mounts_active() {
    local devices
    devices="$(lxc config device show "$CONTAINER" 2>/dev/null || true)"
    grep -Fq "$CACHE_DEVICE_NPM_HOME:"  <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_NPM:"  <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_PIP:"  <<<"$devices" \
        && grep -Fq "$CACHE_DEVICE_PLAYWRIGHT:" <<<"$devices"
}

_snapshot_taken_at() {
    local snapshot_name="$1"
    lxc info "$CONTAINER" 2>/dev/null \
        | awk -F'|' -v name="$snapshot_name" '
            $0 ~ /^\+/ {next}
            {
                n=$2
                gsub(/^[ \t]+|[ \t]+$/, "", n)
                if (n == name) {
                    t=$3
                    gsub(/^[ \t]+|[ \t]+$/, "", t)
                    print t
                    exit 0
                }
            }
        '
}

_snapshot_age_human() {
    local taken_at="$1"
    if [[ -z "$taken_at" ]]; then
        echo "unknown"
        return 0
    fi

    local taken_epoch now_epoch age
    taken_epoch="$(date -d "$taken_at" +%s 2>/dev/null || true)"
    now_epoch="$(date +%s)"
    if [[ -z "$taken_epoch" ]]; then
        echo "unknown"
        return 0
    fi

    age=$((now_epoch - taken_epoch))
    if (( age < 60 )); then
        echo "${age}s"
    elif (( age < 3600 )); then
        echo "$((age / 60))m"
    elif (( age < 86400 )); then
        echo "$((age / 3600))h"
    else
        echo "$((age / 86400))d"
    fi
}

_refresh_base_snapshot() {
    _info "Refreshing snapshot '$SNAPSHOT_BASE' ..."
    lxc delete "$CONTAINER/$SNAPSHOT_BASE" 2>/dev/null || true
    lxc snapshot "$CONTAINER" "$SNAPSHOT_BASE"
    _ok "Snapshot '$SNAPSHOT_BASE' refreshed."
}

_refresh_current_snapshot() {
    _info "Refreshing snapshot '$SNAPSHOT_CURRENT' ..."
    lxc delete "$CONTAINER/$SNAPSHOT_CURRENT" 2>/dev/null || true
    lxc snapshot "$CONTAINER" "$SNAPSHOT_CURRENT"
    _ok "Snapshot '$SNAPSHOT_CURRENT' refreshed."
}

_require_base_snapshot() {
    _has_snapshot_base || _fail "Snapshot '$SNAPSHOT_BASE' not found. Run: devctl setup"
}

# ── Source sync ───────────────────────────────────────────────────────────────

_sync_webui_sources() {
    lxc exec "$CONTAINER" -- mkdir -p "$DEV_WEBUI_ROOT"
    tar -C "$PROJECT_ROOT" \
        --exclude='webui/node_modules' \
        --exclude='webui/.svelte-kit' \
        --exclude='webui/build' \
        -czf - webui \
        | lxc exec "$CONTAINER" -- tar -xzf - -C "$DEV_WEBUI_ROOT" --strip-components=1
}

_sync_metrics_dashboard_sources() {
    lxc exec "$CONTAINER" -- mkdir -p "$DEV_METRICS_DASHBOARD_ROOT"
    tar -C "$PROJECT_ROOT" \
        --exclude='metrics/dashboard/node_modules' \
        --exclude='metrics/dashboard/.svelte-kit' \
        --exclude='metrics/dashboard/build' \
        -czf - metrics/dashboard \
        | lxc exec "$CONTAINER" -- tar -xzf - -C "$DEV_METRICS_DASHBOARD_ROOT" --strip-components=2
}

# ── Node version management ───────────────────────────────────────────────────

# Install the exact Node version from .node-version using nvm.
# Symlinks node/npm/npx to /usr/local/bin for non-login-shell access.
# Verifies exact version post-install; hard-fails on mismatch.
_install_node_exact() {
    local node_version="$1"
    _info "Installing Node.js $node_version in container via nvm ..."
    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
export NVM_DIR=/root/.nvm
if [[ ! -f \"\$NVM_DIR/nvm.sh\" ]]; then
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh \
        | PROFILE=/dev/null bash
fi
source \"\$NVM_DIR/nvm.sh\"
nvm install '$node_version'
nvm alias default '$node_version'
nvm use '$node_version'
# Symlink for non-login shells (lxc exec without -l)
node_bin_dir=\"\$(dirname \"\$(nvm which current)\")\"
ln -sf \"\$node_bin_dir/node\" /usr/local/bin/node
ln -sf \"\$node_bin_dir/npm\"  /usr/local/bin/npm
ln -sf \"\$node_bin_dir/npx\"  /usr/local/bin/npx
# Post-install verification — exact version required
actual=\"\$(node --version | tr -d 'v')\"
if [[ \"\$actual\" != '$node_version' ]]; then
    echo \"[devctl] Node install failed: required $node_version, got \$actual\" >&2
    exit 1
fi
echo \"[devctl] Node.js $node_version installed and verified.\""
    _ok "Node.js $node_version installed in container."
}

# Returns the node version string currently in the container (empty if absent).
_get_container_node_version() {
    # Uses /usr/local/bin/node symlink set by _install_node_exact; no nvm needed.
    lxc exec "$CONTAINER" -- bash -c \
        "node --version 2>/dev/null | tr -d 'v' || true" 2>/dev/null \
        | tr -d '[:space:]' || true
}

# Hard-fails if the container's Node version does not match the expected version.
_assert_node_matches_strict() {
    local expected="$1"
    local actual
    actual="$(_get_container_node_version)"
    if [[ "$actual" != "$expected" ]]; then
        _fail "Node version mismatch: required $expected, container has '${actual:-NONE}'. Run: devctl setup"
    fi
    _info "Node version verified: $actual"
}

# ── Stack install and drift detection ─────────────────────────────────────────

# Full install for one stack: sync full sources → rm node_modules/.svelte-kit
# → npm ci → write manifest hash. npm ci is lockfile-authoritative and is
# intentionally used for deterministic replay (setup/ensure-stack-ready paths).
# Used by cmd_setup and Node-drift recovery.
_install_stack() {
    local stack="$1"
    local container_root container_hash_file
    if [[ "$stack" == "webui" ]]; then
        container_root="$DEV_WEBUI_ROOT"
        container_hash_file="/opt/nightfall-manifest/webui.hash"
        _sync_webui_sources
    else
        container_root="$DEV_METRICS_DASHBOARD_ROOT"
        container_hash_file="/opt/nightfall-manifest/dashboard.hash"
        _sync_metrics_dashboard_sources
    fi
    lxc exec "$CONTAINER" -- mkdir -p "$container_root" /opt/nightfall-manifest
    lxc exec "$CONTAINER" -- bash -c "
set -euo pipefail
cd '$container_root'
rm -rf node_modules .svelte-kit
npm ci
cat package.json package-lock.json | sha256sum | awk '{print \$1}' > '$container_hash_file'"
    _ok "$stack stack installed. Hash written."
}

# Regenerate a stack lockfile from package manifests inside the container.
# This path is manifest-authoritative by design (npm install), unlike
# _install_stack which is lockfile-authoritative (npm ci).
_regenerate_stack() {
    local stack="$1"
    local container_root container_hash_file
    if [[ "$stack" == "webui" ]]; then
        container_root="$DEV_WEBUI_ROOT"
        container_hash_file="/opt/nightfall-manifest/webui.hash"
    elif [[ "$stack" == "dashboard" ]]; then
        container_root="$DEV_METRICS_DASHBOARD_ROOT"
        container_hash_file="/opt/nightfall-manifest/dashboard.hash"
    else
        _fail "Unknown stack for _regenerate_stack: $stack"
        return 1
    fi

    _info "Regenerating lockfile for $stack (npm install) ..."
    lxc exec "$CONTAINER" -- mkdir -p "$container_root" /opt/nightfall-manifest
    lxc exec "$CONTAINER" -- bash -c "
set -euo pipefail
cd '$container_root'
rm -rf node_modules .svelte-kit
npm install
cat package.json package-lock.json | sha256sum | awk '{print \$1}' > '$container_hash_file'"
    _ok "$stack lockfile regenerated in container."
}

_pull_lockfile() {
    local stack="$1"
    local container_root host_dir
    if [[ "$stack" == "webui" ]]; then
        container_root="$DEV_WEBUI_ROOT"
        host_dir="$PROJECT_ROOT/webui"
    elif [[ "$stack" == "dashboard" ]]; then
        container_root="$DEV_METRICS_DASHBOARD_ROOT"
        host_dir="$PROJECT_ROOT/metrics/dashboard"
    else
        _fail "Unknown stack for _pull_lockfile: $stack"
        return 1
    fi

    _info "Pulling $stack package-lock.json from container to host ..."
    lxc file pull "$CONTAINER$container_root/package-lock.json" "$host_dir/package-lock.json"
    [[ -f "$host_dir/package-lock.json" ]] \
        || _fail "Pulled lockfile missing on host for stack '$stack': $host_dir/package-lock.json"
    _ok "$stack lockfile pulled to host."
}

_recalculate_host_hash() {
    local stack="$1"
    local stack_dir
    if [[ "$stack" == "webui" ]]; then
        stack_dir="$PROJECT_ROOT/webui"
    elif [[ "$stack" == "dashboard" ]]; then
        stack_dir="$PROJECT_ROOT/metrics/dashboard"
    else
        _fail "Unknown stack for _recalculate_host_hash: $stack"
        return 1
    fi

    if [[ ! -f "$stack_dir/package.json" || ! -f "$stack_dir/package-lock.json" ]]; then
        _fail "Missing manifest files for stack '$stack' in $stack_dir"
        return 1
    fi

    cat "$stack_dir/package.json" "$stack_dir/package-lock.json" | sha256sum | awk '{print $1}'
}

# Drift detection for a single stack.
# MUST be called AFTER _sync_{webui,metrics_dashboard}_sources so the container
# holds the current host manifests before any npm ci runs.
# Reinstalls only if host manifest hash differs from the stored container hash.
_drift_check_stack() {
    local stack="$1"
    local stack_dir container_root container_hash_file host_hash container_hash
    if [[ "$stack" == "webui" ]]; then
        stack_dir="$PROJECT_ROOT/webui"
        container_root="$DEV_WEBUI_ROOT"
        container_hash_file="/opt/nightfall-manifest/webui.hash"
    else
        stack_dir="$PROJECT_ROOT/metrics/dashboard"
        container_root="$DEV_METRICS_DASHBOARD_ROOT"
        container_hash_file="/opt/nightfall-manifest/dashboard.hash"
    fi

    if [[ ! -f "$stack_dir/package.json" || ! -f "$stack_dir/package-lock.json" ]]; then
        _fail "$stack: missing package.json or package-lock.json in $stack_dir"
    fi

    host_hash="$(cat "$stack_dir/package.json" "$stack_dir/package-lock.json" \
        | sha256sum | awk '{print $1}')"
    container_hash="$(lxc exec "$CONTAINER" -- \
        bash -c "cat '$container_hash_file' 2>/dev/null | tr -d '[:space:]' || true")"

    if [[ "$host_hash" != "$container_hash" ]]; then
        _warn "$stack manifest drift (host=$host_hash container=${container_hash:-MISSING}). Reinstalling ..."
        lxc exec "$CONTAINER" -- mkdir -p /opt/nightfall-manifest
        lxc exec "$CONTAINER" -- bash -c "
set -euo pipefail
cd '$container_root'
rm -rf node_modules .svelte-kit
npm ci
cat package.json package-lock.json | sha256sum | awk '{print \$1}' > '$container_hash_file'"
        _ok "$stack stack reinstalled. Hash updated."
    else
        _ok "$stack stack up to date (hash=$host_hash)."
    fi
}

# Strict drift assertion — no remediation.  Hard-fails if drift remains.
# Used as a post-remediation gate before snapshot creation.
_assert_stack_no_drift() {
    local stack="$1"
    local stack_dir container_hash_file host_hash container_hash
    if [[ "$stack" == "webui" ]]; then
        stack_dir="$PROJECT_ROOT/webui"
        container_hash_file="/opt/nightfall-manifest/webui.hash"
    else
        stack_dir="$PROJECT_ROOT/metrics/dashboard"
        container_hash_file="/opt/nightfall-manifest/dashboard.hash"
    fi

    host_hash="$(cat "$stack_dir/package.json" "$stack_dir/package-lock.json" \
        | sha256sum | awk '{print $1}')"
    container_hash="$(lxc exec "$CONTAINER" -- \
        bash -c "cat '$container_hash_file' 2>/dev/null | tr -d '[:space:]' || true")"

    if [[ "$host_hash" != "$container_hash" ]]; then
        _fail "$stack drift remains after remediation (host=$host_hash container=${container_hash:-MISSING}). Run: devctl setup"
    fi
    _info "$stack no-drift verified: $host_hash"
}

# ── Stack readiness (entry point for all test/run commands) ───────────────────

# Ensures both or one stack is in sync with the host.
# Checks: SvelteKit/Vite major consistency (host) → Node version (container)
#         → source sync → manifest drift detection (per-stack).
# On Node drift: reinstalls both stacks unconditionally (native addons may be
# compiled for the old Node ABI).
_ensure_stack_ready() {
    local target="${1:-all}"
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"

    local node_version
    node_version="$(get_node_version)"
    [[ -n "$node_version" ]] || _fail "No .node-version file found in project root."

    # SvelteKit and Vite major versions must be consistent across both stacks.
    assert_web_stack_major_consistency

    # Node version drift check — ABI-level change requires reinstalling all stacks.
    local actual_node
    actual_node="$(_get_container_node_version)"
    if [[ "$actual_node" != "$node_version" ]]; then
        _warn "Node drift: required $node_version, container has '${actual_node:-NONE}'. Reinstalling Node + both stacks ..."
        _install_node_exact "$node_version"
        _install_stack webui
        _install_stack dashboard
        return 0
    fi

    # Per-stack drift detection; sources synced before drift check.
    if [[ "$target" == "webui" || "$target" == "all" ]]; then
        _sync_webui_sources
        _drift_check_stack webui
    fi
    if [[ "$target" == "dashboard" || "$target" == "all" ]]; then
        _sync_metrics_dashboard_sources
        _drift_check_stack dashboard
    fi
}

cmd_ensure_stack_ready() {
    local target="${1:-all}"
    case "$target" in
        webui|dashboard|all) ;;
        *) _fail "Usage: devctl ensure-stack-ready [webui|dashboard|all]" ;;
    esac
    _ensure_stack_ready "$target"
    _ok "Stack ready: $target"
}

# ── Python toolchain (private — called only from cmd_setup) ───────────────────

_bootstrap_python_toolchain() {
    if lxc exec "$CONTAINER" -- test -f "$MARKER_PYTHON" 2>/dev/null; then
        _ok "Python bootstrap already complete (marker present). Skipping."
        return 0
    fi
    _info "Installing Python toolchain in container ..."
    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
apt-get update -qq
apt-get install -y --no-install-recommends python3 python3-pip python3-venv
python3 -m venv '$DEV_VENV_ROOT'
'$DEV_VENV_ROOT'/bin/pip install --quiet --upgrade pip pytest pytest-asyncio httpx testcontainers
touch '$MARKER_PYTHON'"
    _ok "Python bootstrap completed in $DEV_VENV_ROOT."
}

# ── Container lifecycle commands ──────────────────────────────────────────────

cmd_create() {
    cmd_setup "$@"
}

cmd_setup() {
    # Atomic bootstrap: create container → cache mounts → exact Node (nvm) →
    # Python toolchain → webui stack (npm ci) → dashboard stack (npm ci) →
    # manifest hashes → base snapshot.
    if lxc info "$CONTAINER" &>/dev/null; then
        _warn "Container '$CONTAINER' already exists. Ensuring cache mounts are configured."
    else
        _info "Launching container $CONTAINER (ubuntu:24.04, profiles: $PROFILE_DEFAULT+$PROFILE_DEV) ..."
        lxc launch ubuntu:24.04 "$CONTAINER" -p "$PROFILE_DEFAULT" -p "$PROFILE_DEV"
    fi

    _info "Configuring cache bind mounts ..."
    _ensure_cache_mounts

    if [[ "$(lxc list "$CONTAINER" -c s --format csv 2>/dev/null | tr -d '\r')" != "RUNNING" ]]; then
        _info "Starting container ..."
        lxc start "$CONTAINER"
    fi

    _info "Waiting for container readiness ..."
    _wait_ready

    # Validate SvelteKit/Vite major consistency across both stacks before install.
    assert_web_stack_major_consistency

    # Exact Node install via nvm — version sourced from .node-version.
    local node_version
    node_version="$(get_node_version)"
    [[ -n "$node_version" ]] || _fail "No .node-version file found in project root."
    _install_node_exact "$node_version"

    # Python toolchain (marker-based idempotency; not manifest-sensitive).
    _bootstrap_python_toolchain

    # Bootstrap both web stacks via npm ci (lockfile-only, no synthetic installs).
    _info "Bootstrapping webui stack ..."
    _install_stack webui

    _info "Bootstrapping metrics dashboard stack ..."
    _install_stack dashboard

    # setup establishes the baseline; remove any rolling snapshot before
    # refreshing base so reset semantics remain deterministic.
    lxc delete "$CONTAINER/$SNAPSHOT_CURRENT" 2>/dev/null || true

    # Create the base snapshot that reset/assert-cached-ready depend on.
    _refresh_base_snapshot

    _ok "Atomic bootstrap complete."
    _info "Installed Node.js:       $node_version"
    _info "Webui hash:              $(lxc exec "$CONTAINER" -- cat /opt/nightfall-manifest/webui.hash)"
    _info "Dashboard hash:          $(lxc exec "$CONTAINER" -- cat /opt/nightfall-manifest/dashboard.hash)"
}

cmd_destroy() {
    _info "Deleting container $CONTAINER ..."
    lxc delete --force "$CONTAINER" 2>/dev/null || true
    _ok "Development container deleted."
}

cmd_reset() {
    nf_require_container_exists "$CONTAINER" "devctl setup" "devctl"

    local force_base=0
    case "${1:-}" in
        "")
            ;;
        --base)
            force_base=1
            ;;
        *)
            _fail "Usage: devctl reset [--base]"
            ;;
    esac

    local restore_snapshot=""
    if (( force_base )); then
        _require_base_snapshot
        restore_snapshot="$SNAPSHOT_BASE"
    elif _has_snapshot_current; then
        restore_snapshot="$SNAPSHOT_CURRENT"
    else
        _require_base_snapshot
        restore_snapshot="$SNAPSHOT_BASE"
    fi

    _info "Stopping container ..."
    lxc stop "$CONTAINER" --force 2>/dev/null || true

    _info "Restoring snapshot '$restore_snapshot' ..."
    lxc restore "$CONTAINER" "$restore_snapshot"

    _info "Starting container ..."
    lxc start "$CONTAINER"
    _wait_ready

    _ok "Development container restored to '$restore_snapshot'."
}

cmd_snapshot_create() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"

    local node_version
    node_version="$(get_node_version)"

    # Strict Node guard: snapshot must reflect the pinned version exactly.
    _assert_node_matches_strict "$node_version"

    # Sync sources then drift-check both stacks; reinstalls if manifests changed.
    _sync_webui_sources
    _drift_check_stack webui

    _sync_metrics_dashboard_sources
    _drift_check_stack dashboard

    # Post-remediation strict assertions: snapshot is only valid when
    # both stacks are verifiably drift-free.
    _assert_stack_no_drift webui
    _assert_stack_no_drift dashboard

    _refresh_base_snapshot
}

cmd_snapshot_refresh() {
    cmd_snapshot_create
}

cmd_update() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"

    local scope=""
    local simulate=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --simulate)
                simulate=1
                shift
                ;;
            --scope)
                shift
                [[ $# -gt 0 ]] || _fail "Usage: devctl update [--scope node|webui|dashboard|all] [--simulate]"
                scope="$1"
                shift
                ;;
            --scope=*)
                scope="${1#*=}"
                shift
                ;;
            *)
                _fail "Usage: devctl update [--scope node|webui|dashboard|all] [--simulate]"
                ;;
        esac
    done

    case "${scope:-auto}" in
        auto|node|webui|dashboard|all) ;;
        *) _fail "Invalid --scope value: ${scope}. Use one of: node|webui|dashboard|all" ;;
    esac

    local expected_node actual_node node_drift=0
    expected_node="$(get_node_version)"
    [[ -n "$expected_node" ]] || _fail "No .node-version file found in project root."
    actual_node="$(_get_container_node_version)"
    if [[ "$actual_node" != "$expected_node" ]]; then
        node_drift=1
    fi

    local _host_manifest_hash _container_manifest_hash
    _host_manifest_hash() {
        local stack="$1"
        local stack_dir
        if [[ "$stack" == "webui" ]]; then
            stack_dir="$PROJECT_ROOT/webui"
        else
            stack_dir="$PROJECT_ROOT/metrics/dashboard"
        fi
        [[ -f "$stack_dir/package.json" && -f "$stack_dir/package-lock.json" ]] || return 1
        cat "$stack_dir/package.json" "$stack_dir/package-lock.json" | sha256sum | awk '{print $1}'
    }
    _container_manifest_hash() {
        local stack="$1"
        local hash_file
        if [[ "$stack" == "webui" ]]; then
            hash_file="/opt/nightfall-manifest/webui.hash"
        else
            hash_file="/opt/nightfall-manifest/dashboard.hash"
        fi
        lxc exec "$CONTAINER" -- bash -c "cat '$hash_file' 2>/dev/null | tr -d '[:space:]' || true"
    }

    local web_host_hash web_container_hash web_drift=0
    local dashboard_host_hash dashboard_container_hash dashboard_drift=0

    web_host_hash="$(_host_manifest_hash webui || true)"
    web_container_hash="$(_container_manifest_hash webui || true)"
    if [[ -z "$web_host_hash" || -z "$web_container_hash" || "$web_host_hash" != "$web_container_hash" ]]; then
        web_drift=1
    fi

    dashboard_host_hash="$(_host_manifest_hash dashboard || true)"
    dashboard_container_hash="$(_container_manifest_hash dashboard || true)"
    if [[ -z "$dashboard_host_hash" || -z "$dashboard_container_hash" || "$dashboard_host_hash" != "$dashboard_container_hash" ]]; then
        dashboard_drift=1
    fi

    local resolved_scope="$scope"
    if [[ -z "$resolved_scope" ]]; then
        if (( node_drift )); then
            resolved_scope="all"
        elif (( web_drift && dashboard_drift )); then
            resolved_scope="all"
        elif (( web_drift )); then
            resolved_scope="webui"
        elif (( dashboard_drift )); then
            resolved_scope="dashboard"
        else
            resolved_scope="none"
        fi
    fi

    if [[ "$resolved_scope" == "node" ]]; then
        resolved_scope="all"
    fi
    if (( node_drift )) && [[ "$resolved_scope" != "all" ]]; then
        _warn "Node drift detected; escalating scope to all"
        resolved_scope="all"
    fi

    if (( simulate )); then
        if (( node_drift )); then
            _warn "Node drift: expected=$expected_node actual=${actual_node:-NONE}"
        else
            _ok "Node drift: none ($expected_node)"
        fi

        if (( web_drift )); then
            _warn "webui manifest drift: host=${web_host_hash:-MISSING} container=${web_container_hash:-MISSING}"
        else
            _ok "webui manifest drift: none (${web_host_hash:-UNKNOWN})"
        fi

        if (( dashboard_drift )); then
            _warn "dashboard manifest drift: host=${dashboard_host_hash:-MISSING} container=${dashboard_container_hash:-MISSING}"
        else
            _ok "dashboard manifest drift: none (${dashboard_host_hash:-UNKNOWN})"
        fi

        _info "Effective scope: $resolved_scope"
        case "$resolved_scope" in
            none)
                _info "Planned operations: none" ;;
            webui)
                _info "Planned operations: sync/regenerate/pull webui" ;;
            dashboard)
                _info "Planned operations: sync/regenerate/pull dashboard" ;;
            all)
                _info "Planned operations: sync/regenerate/pull webui+dashboard"
                if (( node_drift )); then
                    _info "Planned operations: install exact Node $expected_node"
                fi
                ;;
        esac

        if (( node_drift || web_drift || dashboard_drift )); then
            _warn "Simulation result: drift detected"
            return 1
        fi
        _ok "Simulation result: no drift detected"
        return 0
    fi

    if [[ "$scope" == "" && "$resolved_scope" == "none" ]]; then
        _ok "No drift detected; update has nothing to do."
        return 0
    fi

    if (( node_drift )); then
        _warn "Node drift: expected=$expected_node actual=${actual_node:-NONE}; reinstalling exact Node"
        _install_node_exact "$expected_node"
    fi

    assert_web_stack_major_consistency

    local stack
    if [[ "$resolved_scope" == "webui" || "$resolved_scope" == "all" ]]; then
        _sync_webui_sources
        _regenerate_stack webui
        _pull_lockfile webui
        _info "webui host hash after pullback: $(_recalculate_host_hash webui)"
    fi
    if [[ "$resolved_scope" == "dashboard" || "$resolved_scope" == "all" ]]; then
        _sync_metrics_dashboard_sources
        _regenerate_stack dashboard
        _pull_lockfile dashboard
        _info "dashboard host hash after pullback: $(_recalculate_host_hash dashboard)"
    fi

    _assert_stack_no_drift webui
    _assert_stack_no_drift dashboard

    if ! _run_regression_gate; then
        _fail "Update aborted: regression gate failed; current snapshot not refreshed"
        return 1
    fi

    _refresh_current_snapshot
    _ok "Update complete: scope=$resolved_scope node_drift=$node_drift"
}

# ── Run commands ──────────────────────────────────────────────────────────────

cmd_run_webui() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui

    _info "Configuring host loopback proxy for Vite: 127.0.0.1:$DEV_WEBUI_PORT"
    lxc config device remove "$CONTAINER" "$DEV_WEBUI_PROXY_DEVICE" >/dev/null 2>&1 || true
    lxc config device add    "$CONTAINER" "$DEV_WEBUI_PROXY_DEVICE" proxy \
        listen="tcp:127.0.0.1:$DEV_WEBUI_PORT" \
        connect="tcp:127.0.0.1:$DEV_WEBUI_PORT"

    _ok "Dev web UI URL: http://127.0.0.1:$DEV_WEBUI_PORT/"
    _info "Starting Vite dev server in container (Ctrl+C to stop)."

    lxc exec -t "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
npx svelte-kit sync
npm run dev -- --host 0.0.0.0 --port '$DEV_WEBUI_PORT'"
}

cmd_run_api() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _warn "API run scaffold is not yet implemented. Use 'devctl shell' and run the API manually."
}

# ── Test commands ─────────────────────────────────────────────────────────────

cmd_test_web_unit() {
    if [[ -n "${DEVCTL_CONTRACT_TEST_ROOT:-}" ]]; then
        local web_root="$DEVCTL_CONTRACT_TEST_ROOT"
        local typecheck_runner="${DEVCTL_TEST_WEB_TYPECHECK_RUNNER:-npm exec -- svelte-check --fail-on-warnings}"
        local unit_runner="${DEVCTL_TEST_WEB_UNIT_RUNNER:-npx vitest run}"

        [[ -d "$web_root" ]] || _fail "Contract test root not found: $web_root"

        if [[ ! -d "$web_root/tests/component" ]]; then
            echo '[devctl] Missing tests/component directory in $DEV_WEBUI_ROOT' >&2
            return 1
        fi

        local count
        count="$(find "$web_root/tests/component" -type f \
            \( -name '*.test.ts' -o -name '*.test.js' \
               -o -name '*.spec.ts' -o -name '*.spec.js' \) \
            | wc -l | tr -d '[:space:]')"
        if [[ "$count" == "0" ]]; then
            echo '[devctl] No tests/component test files found' >&2
            return 1
        fi

        echo "[devctl] Discovered $count tests/component test file(s)."
        (cd "$web_root" && bash -lc "$typecheck_runner")
        (cd "$web_root" && bash -lc "$unit_runner")

        _ok "test-web-unit completed successfully."
        return 0
    fi

    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    # Sources synced + drift fixed inside _ensure_stack_ready.
    _ensure_stack_ready webui

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
    npx svelte-kit sync
if [[ ! -d tests/component ]]; then
    echo '[devctl] Missing tests/component directory in $DEV_WEBUI_ROOT' >&2
    exit 1
fi
count=\$(find tests/component -type f \
    \( -name '*.test.ts' -o -name '*.test.js' \
       -o -name '*.spec.ts' -o -name '*.spec.js' \) \
    | wc -l | tr -d '[:space:]')
if [[ \"\$count\" == \"0\" ]]; then
    echo '[devctl] No tests/component test files found' >&2
    exit 1
fi
echo \"[devctl] Discovered \$count tests/component test file(s).\"
npm exec -- svelte-check --fail-on-warnings
npx vitest run"

    _ok "test-web-unit completed successfully."
}

cmd_test_web_typecheck() {
    if [[ -n "${DEVCTL_CONTRACT_TEST_ROOT:-}" ]]; then
        local web_root="$DEVCTL_CONTRACT_TEST_ROOT"
        local typecheck_runner="${DEVCTL_TEST_WEB_TYPECHECK_RUNNER:-npm exec -- svelte-check --fail-on-warnings}"

        [[ -d "$web_root" ]] || _fail "Contract test root not found: $web_root"
        (cd "$web_root" && bash -lc "$typecheck_runner")

        _ok "test-web-typecheck completed successfully."
        return 0
    fi

    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
npx svelte-kit sync
npm exec -- svelte-check --fail-on-warnings"

    _ok "test-web-typecheck completed successfully."
}

cmd_test_metrics_dashboard_typecheck() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready dashboard

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_METRICS_DASHBOARD_ROOT'
npx svelte-kit sync
npm exec -- svelte-check --fail-on-warnings"

    _ok "test-metrics-dashboard-typecheck completed successfully."
}

cmd_test_web_e2e() {
    local artifact_dir="${DEVCTL_E2E_ARTIFACT_DIR:-test-results/playwright}"

    if [[ -n "${DEVCTL_CONTRACT_TEST_ROOT:-}" ]]; then
        local web_root="$DEVCTL_CONTRACT_TEST_ROOT"
        local e2e_runner="${DEVCTL_TEST_WEB_E2E_RUNNER:-npx playwright test --reporter=line}"

        [[ -d "$web_root" ]] || _fail "Contract test root not found: $web_root"

        if [[ ! -d "$web_root/tests/e2e" ]]; then
            echo '[devctl] WARN: tests/e2e directory missing; skipping E2E run.'
            _ok "test-web-e2e completed successfully (or skipped when no e2e specs exist)."
            return 0
        fi

        local count
        count="$(find "$web_root/tests/e2e" -type f \
            \( -name '*.spec.ts' -o -name '*.spec.js' \) \
            | wc -l | tr -d '[:space:]')"
        if [[ "$count" == "0" ]]; then
            echo '[devctl] WARN: No tests/e2e spec files found; skipping E2E run.'
            _ok "test-web-e2e completed successfully (or skipped when no e2e specs exist)."
            return 0
        fi

        echo "[devctl] Discovered $count tests/e2e spec file(s)."
        mkdir -p "$web_root/$artifact_dir"
        echo "E2E_ARTIFACT_PATH=$web_root/$artifact_dir"
        (cd "$web_root" && bash -lc "$e2e_runner")

        _ok "test-web-e2e completed successfully."
        return 0
    fi

    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    _ensure_stack_ready webui

    lxc exec "$CONTAINER" -- bash -lc "
set -euo pipefail
cd '$DEV_WEBUI_ROOT'
if [[ ! -d tests/e2e ]]; then
        echo '[devctl] WARN: tests/e2e directory missing; skipping E2E run.'
        exit 0
fi
count=\$(find tests/e2e -type f \
    \( -name '*.spec.ts' -o -name '*.spec.js' \) \
    | wc -l | tr -d '[:space:]')
if [[ \"\$count\" == \"0\" ]]; then
        echo '[devctl] WARN: No tests/e2e spec files found; skipping E2E run.'
        exit 0
fi
echo \"[devctl] Discovered \$count tests/e2e spec file(s).\"
mkdir -p '$artifact_dir'
echo \"E2E_ARTIFACT_PATH=$DEV_WEBUI_ROOT/$artifact_dir\"
npx playwright test --reporter=line"

    _ok "test-web-e2e completed successfully (or skipped when no e2e specs exist)."
}

# Run the full regression gate used by update flows.
# Caller is expected to hold the global repo lock.
_run_regression_gate() {
    local total_start total_elapsed
    total_start="$(date +%s)"

    _info "Regression gate: starting"

    local suite_start suite_elapsed

    suite_start="$(date +%s)"
    if ! cmd_test_web_typecheck; then
        _fail "Regression gate failed: test-web-typecheck"
        return 1
    fi
    suite_elapsed=$(( $(date +%s) - suite_start ))
    _info "Regression gate: test-web-typecheck passed (${suite_elapsed}s)"

    suite_start="$(date +%s)"
    if ! cmd_test_metrics_dashboard_typecheck; then
        _fail "Regression gate failed: test-metrics-dashboard-typecheck"
        return 1
    fi
    suite_elapsed=$(( $(date +%s) - suite_start ))
    _info "Regression gate: test-metrics-dashboard-typecheck passed (${suite_elapsed}s)"

    suite_start="$(date +%s)"
    if ! cmd_test_web_unit; then
        _fail "Regression gate failed: test-web-unit"
        return 1
    fi
    suite_elapsed=$(( $(date +%s) - suite_start ))
    _info "Regression gate: test-web-unit passed (${suite_elapsed}s)"

    suite_start="$(date +%s)"
    if ! DEVCTL_GLOBAL_LOCK_HELD=1 "$PROJECT_ROOT/.venv/bin/python" -m pytest tests/unit; then
        _fail "Regression gate failed: pytest tests/unit"
        return 1
    fi
    suite_elapsed=$(( $(date +%s) - suite_start ))
    _info "Regression gate: pytest tests/unit passed (${suite_elapsed}s)"

    total_elapsed=$(( $(date +%s) - total_start ))
    _ok "Regression gate passed (${total_elapsed}s total)"
}

# ── Status / utility commands ─────────────────────────────────────────────────

cmd_assert_cached_ready() {
    nf_require_container_exists "$CONTAINER" "devctl setup" "devctl"

    _cache_mounts_active \
        || _fail "Cache mounts not fully configured. Run: devctl setup"

    if _has_snapshot_current; then
        _ok "Snapshot readiness: '$SNAPSHOT_CURRENT' present"
    elif _has_snapshot_base; then
        _ok "Snapshot readiness: '$SNAPSHOT_BASE' present"
    else
        _fail "No snapshot found ('$SNAPSHOT_CURRENT' or '$SNAPSHOT_BASE'). Run: devctl setup"
    fi

    _ok "Cache mounts and snapshot state are ready."
}

cmd_status() {
    if lxc info "$CONTAINER" &>/dev/null; then
        lxc info "$CONTAINER"
        if _has_snapshot_base; then
            _ok  "Snapshot status: '$SNAPSHOT_BASE' present"
        else
            _warn "Snapshot status: '$SNAPSHOT_BASE' missing"
        fi
        if _has_snapshot_current; then
            _ok  "Snapshot status: '$SNAPSHOT_CURRENT' present"
        else
            _warn "Snapshot status: '$SNAPSHOT_CURRENT' missing"
        fi
        if _cache_mounts_active; then
            _ok  "Cache mounts: active"
        else
            _warn "Cache mounts: incomplete"
        fi
        _info "Configured cache mounts:"
        _print_cache_mounts
    else
        _warn "Container '$CONTAINER' does not exist."
    fi
}

cmd_check() {
    local has_drift=0
    local container_running=0

    if [[ "$(lxc list "$CONTAINER" -c s --format csv 2>/dev/null | tr -d '\r')" == "RUNNING" ]]; then
        container_running=1
    fi

    _info "Drift check (read-only)"

    # Node drift
    local expected_node actual_node
    expected_node="$(get_node_version)"
    if [[ -z "$expected_node" ]]; then
        _warn "Node expected version: missing (.node-version/.nvmrc not found)"
        has_drift=1
    else
        if (( container_running )); then
            actual_node="$(_get_container_node_version)"
            if [[ "$actual_node" == "$expected_node" ]]; then
                _ok "Node drift: none ($expected_node)"
            else
                _warn "Node drift: expected=$expected_node actual=${actual_node:-NONE}"
                has_drift=1
            fi
        else
            _warn "Node drift: container not running (expected=$expected_node)"
            has_drift=1
        fi
    fi

    # Per-stack manifest drift
    local stack stack_dir container_hash_file host_hash container_hash
    for stack in webui dashboard; do
        if [[ "$stack" == "webui" ]]; then
            stack_dir="$PROJECT_ROOT/webui"
            container_hash_file="/opt/nightfall-manifest/webui.hash"
        else
            stack_dir="$PROJECT_ROOT/metrics/dashboard"
            container_hash_file="/opt/nightfall-manifest/dashboard.hash"
        fi

        if [[ ! -f "$stack_dir/package.json" || ! -f "$stack_dir/package-lock.json" ]]; then
            _warn "$stack manifest drift: host manifest files missing"
            has_drift=1
            continue
        fi

        host_hash="$(cat "$stack_dir/package.json" "$stack_dir/package-lock.json" | sha256sum | awk '{print $1}')"
        if (( container_running )); then
            container_hash="$(lxc exec "$CONTAINER" -- \
                bash -c "cat '$container_hash_file' 2>/dev/null | tr -d '[:space:]' || true")"
            if [[ -n "$container_hash" && "$host_hash" == "$container_hash" ]]; then
                _ok "$stack manifest drift: none ($host_hash)"
            else
                _warn "$stack manifest drift: host=$host_hash container=${container_hash:-MISSING}"
                has_drift=1
            fi
        else
            _warn "$stack manifest drift: container not running"
            has_drift=1
        fi
    done

    # Snapshot status and age (informational)
    local taken_base taken_current
    if _has_snapshot_base; then
        taken_base="$(_snapshot_taken_at "$SNAPSHOT_BASE")"
        _ok "Snapshot '$SNAPSHOT_BASE': present (taken='$taken_base', age=$(_snapshot_age_human "$taken_base"))"
    else
        _warn "Snapshot '$SNAPSHOT_BASE': missing"
        has_drift=1
    fi

    if _has_snapshot_current; then
        taken_current="$(_snapshot_taken_at "$SNAPSHOT_CURRENT")"
        _info "Snapshot '$SNAPSHOT_CURRENT': present (taken='$taken_current', age=$(_snapshot_age_human "$taken_current"))"
    else
        _info "Snapshot '$SNAPSHOT_CURRENT': not present"
    fi

    # Stack major consistency check
    if assert_web_stack_major_consistency >/dev/null 2>&1; then
        _ok "SvelteKit/Vite major consistency: OK"
    else
        _warn "SvelteKit/Vite major consistency: mismatch"
        has_drift=1
    fi

    if (( has_drift )); then
        _warn "Check result: drift detected"
        return 1
    fi

    _ok "Check result: no drift detected"
}

cmd_shell() {
    nf_require_container_running "$CONTAINER" "devctl setup" "devctl"
    lxc exec -t "$CONTAINER" -- bash
}

_usage() {
    cat <<USAGE
Usage: $(basename "$0") <command>

Commands:
  setup                             Atomic bootstrap: create/start container, install exact Node
                                    (nvm), Python toolchain, both web stacks (npm ci), snapshot.
  destroy                           Delete development container.
    reset [--base]                    Restore from snapshot '$SNAPSHOT_CURRENT' when present,
                                                                        otherwise '$SNAPSHOT_BASE'. With --base, always restore '$SNAPSHOT_BASE'.
    update [--scope S] [--simulate]   Unified update flow with lockfile regeneration and regression gate.
                                                                        Scope: node|webui|dashboard|all (default auto-detect).
    check                             Read-only drift report (Node, manifests, snapshots, toolchain majors).
  ensure-stack-ready [target]       Sync sources and drift-check; target: webui|dashboard|all.
    assert-cached-ready               Verify cache mounts and snapshot readiness are present.
  run-api                           API run scaffold (not yet implemented).
  run-webui                         Sync webui sources and start Vite dev server.
  test-web-typecheck                Run webui Svelte/TypeScript typecheck.
  test-metrics-dashboard-typecheck  Run metrics dashboard Svelte/TypeScript typecheck.
  test-web-unit                     Run Vitest unit/component tests.
  test-web-e2e                      Run Playwright e2e browser tests.
  status                            Show container, snapshot, and cache mount status.
  shell                             Open interactive shell in development container.

Environment variables:
  DEV_WEBUI_PORT            Vite dev server port (default: 5173).
  DEVCTL_E2E_ARTIFACT_DIR   Playwright artifact directory (default: test-results/playwright).
  DEVCTL_GLOBAL_LOCK_HELD   Set to 1 by callers that already hold the global repo lock.
  REPO_LOCK_TIMEOUT_SEC     Global repo lock wait timeout in seconds (default: 300).
    DEVCTL_CONTRACT_TEST_ROOT Contract-test mode root path (host execution; bypasses container).
    DEVCTL_TEST_WEB_TYPECHECK_RUNNER
                                                        Contract-test override for web typecheck command (default: npm exec -- svelte-check --fail-on-warnings).
    DEVCTL_TEST_WEB_UNIT_RUNNER
                                                        Contract-test override for web unit test command (default: npx vitest run).
    DEVCTL_TEST_WEB_E2E_RUNNER
                                                        Contract-test override for web e2e command (default: npx playwright test --reporter=line).

Notes:
    Contract-test overrides are intended for unit/contract harnesses only.
    When DEVCTL_CONTRACT_TEST_ROOT is set, web test commands run on the host
    against that path and do not require container dependencies.
USAGE
    exit 1
}

main() {
    local cmd="${1:-}"
    shift || true

    _acquire_command_lock "$cmd"

    case "$cmd" in
        setup)                            cmd_setup "$@" ;;
        destroy)                          cmd_destroy "$@" ;;
        reset)                            cmd_reset "$@" ;;
        update)                           cmd_update "$@" ;;
        check)                            cmd_check "$@" ;;
        ensure-stack-ready)               cmd_ensure_stack_ready "$@" ;;
        assert-cached-ready)              cmd_assert_cached_ready "$@" ;;
        run-api)                          cmd_run_api "$@" ;;
        run-webui)                        cmd_run_webui "$@" ;;
        test-web-typecheck)               cmd_test_web_typecheck "$@" ;;
        test-metrics-dashboard-typecheck) cmd_test_metrics_dashboard_typecheck "$@" ;;
        test-web-unit)                    cmd_test_web_unit "$@" ;;
        test-web-e2e)                     cmd_test_web_e2e "$@" ;;
        status)                           cmd_status "$@" ;;
        shell)                            cmd_shell "$@" ;;
        *)                                _usage ;;
    esac
}

main "$@"
