#!/usr/bin/env bash
# stagingctl — LXC staging controller for nightfall-photo-ingress
#
# Usage:
#   stagingctl create            create container baseline
#   stagingctl install [wheel]   push wheel + config, enable service, refresh "clean" snapshot
#   stagingctl uninstall         delete container
#   stagingctl reset             restore "clean" snapshot, restart
#   stagingctl smoke             run headless smoke assertions, collect evidence
#   stagingctl auth-setup        run interactive device-code auth inside the container
#   stagingctl smoke-live        run authenticated live poll + secret scan
#   stagingctl evidence [run-id] list or inspect evidence runs
#
# Environment variables:
#   STAGING_CLIENT_ID   real Azure client_id to substitute into config
#   STAGING_ACCOUNT     account section name to target for live poll (default: staging)
#   STAGING_TOKEN_JSON  [DEPRECATED] use 'stagingctl auth-setup' instead
#   STAGING_VOLATILE    set to 1 to use /run/staging-photo-ingress/* tmpfs paths

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
STAGING_ROOT="$PROJECT_ROOT/staging"
source "$PROJECT_ROOT/lib/container-common.sh"

# ── container identity ────────────────────────────────────────────────────────
CONTAINER="staging-photo-ingress"
SNAPSHOT_CLEAN="clean"
PROFILE_DEFAULT="default"
PROFILE_STAGING="staging"
STAGING_VOLATILE="${STAGING_VOLATILE:-0}"

# ── container-internal paths ──────────────────────────────────────────────────
VENV_ROOT="/opt/ingress"
CONF_DEST="/etc/nightfall/photo-ingress.conf"
SERVICE_NAME="nightfall-photo-ingress"
API_SERVICE_NAME="nightfall-photo-ingress-api.service"
TRASH_PATH_NAME="nightfall-photo-ingress-trash.path"
TRASH_SERVICE_NAME="nightfall-photo-ingress-trash.service"
SYSTEMD_SOURCE_DIR="$PROJECT_ROOT/systemd"
STAGING_SYSTEMD_DIR="$STAGING_ROOT/systemd"
WEB_BUILD_DIR="$PROJECT_ROOT/webui/build"

if [[ "$STAGING_VOLATILE" == "1" ]]; then
    # Volatile mode: host /run is tmpfs, so evidence/logs are ephemeral.
    HOST_EVIDENCE_BASE="${STAGING_EVIDENCE_BASE:-/run/staging-photo-ingress/evidence}"
    HOST_LOG_BASE="${STAGING_LOG_BASE:-/run/staging-photo-ingress/logs}"
    CT_EVIDENCE_DIR="/run/staging-photo-ingress/evidence"
    CT_LOG_DIR="/run/staging-photo-ingress/logs"
else
    # Persistent mode: evidence/logs stored on ssdpool mount.
    HOST_EVIDENCE_BASE="${STAGING_EVIDENCE_BASE:-/mnt/ssd/staging/photo-ingress/evidence}"
    HOST_LOG_BASE="${STAGING_LOG_BASE:-/mnt/ssd/staging/photo-ingress/logs}"
    CT_EVIDENCE_DIR="/var/lib/ingress/evidence"
    CT_LOG_DIR="/var/log/nightfall"
    CT_TMP_DIR="/root/staging-photo-ingress-tmp"
fi

# ─────────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────────

_info()  { nf_log_info "stagingctl" "$*"; }
_ok()    { nf_log_ok "stagingctl" "$*"; }
_warn()  { nf_log_warn "stagingctl" "$*"; }
_fail()  { nf_log_fail "stagingctl" "$*"; }

_resolve_tmpfs_host_base() {
    if [[ -n "${STAGING_TMPFS_BASE:-}" ]]; then
        printf '%s' "$STAGING_TMPFS_BASE"
        return
    fi

    local user_run_base="/run/user/${UID}"
    if [[ -d "$user_run_base" && -w "$user_run_base" ]]; then
        printf '%s' "$user_run_base/staging-photo-ingress/tmpfs"
    else
        printf '%s' "/run/staging-photo-ingress/tmpfs"
    fi
}

_require_container_running() {
    nf_require_container_running "$CONTAINER" "stagingctl create && stagingctl install" "stagingctl"
}

_require_container_exists() {
    nf_require_container_exists "$CONTAINER" "stagingctl create" "stagingctl"
}

_sanitize_invalid_pillow_distribution() {
    local removed
    removed="$(lxc exec "$CONTAINER" -- bash -lc '
set -e
shopt -s nullglob
count=0
for path in /opt/ingress/lib/python*/site-packages/~illow*; do
    rm -rf "$path"
    count=$((count+1))
done
printf "%s" "$count"
')"

    if [[ "$removed" != "0" ]]; then
        _warn "Removed $removed invalid ~illow artifact(s) from staging venv site-packages."
    fi
}

_assert_no_invalid_distribution_warnings() {
    if lxc exec "$CONTAINER" -- bash -lc \
        'set -e; /opt/ingress/bin/pip list 2>&1 | grep -q -E "invalid distribution|~illow"'; then
        _fail "Detected invalid distribution warning in staging venv after install."
    fi
}

_validate_network_policy() {
    # Ensure container NIC is bridged to br-staging. Do not alter host networking.
    local expanded
    expanded="$(lxc config show "$CONTAINER" --expanded)"
    grep -q "type: nic" <<<"$expanded" \
        || _fail "Container NIC type is not nic (expected type: nic)."
    grep -q "nictype: bridged" <<<"$expanded" \
        || _fail "Container NIC is not bridged (expected nictype: bridged)."
    grep -q "parent: br-staging" <<<"$expanded" \
        || _fail "Container NIC is not attached to br-staging."
}

# Generate a UUIDv4-based run-id prefixed with a sortable timestamp (yyyymmddTHHMMSS).
# Full UUIDv7 support is available in Python 3.13+; this is equivalent for staging purposes.
_gen_run_id() {
    local ts
    ts="$(date -u +%Y%m%dT%H%M%S)"
    local uuid
    uuid="$(python3 -c 'import uuid; print(uuid.uuid4())')"
    printf '%s-%s' "$ts" "$uuid"
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl create
# ─────────────────────────────────────────────────────────────────────────────
cmd_create() {
    if lxc info "$CONTAINER" &>/dev/null; then
        _fail "Container '$CONTAINER' already exists. Run: stagingctl uninstall first."
    fi

    _info "Preparing host evidence/log directories ($([[ "$STAGING_VOLATILE" == "1" ]] && echo volatile || echo persistent)) ..."
    mkdir -p "$HOST_EVIDENCE_BASE" "$HOST_LOG_BASE"
    chmod 777 "$HOST_EVIDENCE_BASE" "$HOST_LOG_BASE"

    _info "Launching container $CONTAINER (ubuntu:24.04, profiles: default+staging) ..."
    lxc launch ubuntu:24.04 "$CONTAINER" -p "$PROFILE_DEFAULT" -p "$PROFILE_STAGING"

    _validate_network_policy

    _info "Waiting for container network ..."
    # Poll until systemd reports running, max 40 s
    local i=0
    while ! lxc exec "$CONTAINER" -- systemctl is-system-running --quiet 2>/dev/null; do
        sleep 2; i=$((i + 2))
        [[ $i -lt 40 ]] || _fail "Container did not become ready within 40 s."
    done

    _info "Running container bootstrap ..."
    lxc exec "$CONTAINER" -- mkdir -p "$CT_TMP_DIR"
    lxc file push "$STAGING_ROOT/container/setup.sh" "$CONTAINER$CT_TMP_DIR/setup.sh"
    lxc exec "$CONTAINER" -- env STAGING_VOLATILE="$STAGING_VOLATILE" bash "$CT_TMP_DIR/setup.sh"
    # Required by hardened unit ReadWritePaths sandboxing.
    lxc exec "$CONTAINER" -- mkdir -p /run/nightfall-status.d
    # Required by trash.service TemporaryFileSystem target path.
    lxc exec "$CONTAINER" -- mkdir -p /var/cache/nightfall-photo-ingress

    # Enforce standard tmp directory semantics inside the container.
    # Staging no longer bind-mounts /tmp or /var/tmp from host /run/user/*.
    lxc exec "$CONTAINER" -- chmod 1777 /tmp /var/tmp || true

    _info "Attaching bind-mounts ..."
    lxc config device add "$CONTAINER" evidence disk \
        source="$HOST_EVIDENCE_BASE" path="$CT_EVIDENCE_DIR"
    lxc config device add "$CONTAINER" logs disk \
        source="$HOST_LOG_BASE" path="$CT_LOG_DIR"

    _info "Installing canonical product systemd units with staging overrides ..."
    lxc file push "$SYSTEMD_SOURCE_DIR/$SERVICE_NAME.service" \
        "$CONTAINER/etc/systemd/system/$SERVICE_NAME.service"
    lxc file push "$SYSTEMD_SOURCE_DIR/$SERVICE_NAME.timer" \
        "$CONTAINER/etc/systemd/system/$SERVICE_NAME.timer"
    lxc file push "$SYSTEMD_SOURCE_DIR/$TRASH_PATH_NAME" \
        "$CONTAINER/etc/systemd/system/$TRASH_PATH_NAME"
    lxc file push "$SYSTEMD_SOURCE_DIR/$TRASH_SERVICE_NAME" \
        "$CONTAINER/etc/systemd/system/$TRASH_SERVICE_NAME"
    lxc exec "$CONTAINER" -- mkdir -p \
        "/etc/systemd/system/$SERVICE_NAME.service.d" \
        "/etc/systemd/system/$SERVICE_NAME.timer.d" \
        "/etc/systemd/system/$TRASH_SERVICE_NAME.d" \
        "/etc/systemd/system/$TRASH_PATH_NAME.d"
    lxc file push "$STAGING_SYSTEMD_DIR/$SERVICE_NAME.service.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$SERVICE_NAME.service.d/override.conf"
    lxc file push "$STAGING_SYSTEMD_DIR/$SERVICE_NAME.timer.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$SERVICE_NAME.timer.d/override.conf"
    lxc file push "$STAGING_SYSTEMD_DIR/$TRASH_SERVICE_NAME.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$TRASH_SERVICE_NAME.d/override.conf"
    lxc file push "$STAGING_SYSTEMD_DIR/$TRASH_PATH_NAME.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$TRASH_PATH_NAME.d/override.conf"
    lxc exec "$CONTAINER" -- systemctl daemon-reload

    _info "Taking LXD snapshot '$SNAPSHOT_CLEAN' ..."
    lxc snapshot "$CONTAINER" "$SNAPSHOT_CLEAN"

    _ok "Container ready. Snapshot '$SNAPSHOT_CLEAN' taken."
    _info "Next step: stagingctl install"
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl install [wheel-path]
# ─────────────────────────────────────────────────────────────────────────────
cmd_install() {
    local wheel_path="${1:-}"

    # Build a fresh wheel by default so staging validates the current tree.
    if [[ -z "$wheel_path" ]]; then
        local build_python
        build_python="python3"
        if [[ -x "$PROJECT_ROOT/.venv/bin/python" ]]; then
            build_python="$PROJECT_ROOT/.venv/bin/python"
        fi
        _info "Building fresh wheel ..."
        (cd "$PROJECT_ROOT" && "$build_python" -m build --wheel --outdir dist/)
        wheel_path="$(ls -t "$PROJECT_ROOT/dist/"*.whl | head -1)"
    fi

    [[ -f "$wheel_path" ]] || _fail "Wheel not found: $wheel_path"
    _require_container_running

    local whl_name
    whl_name="$(basename "$wheel_path")"
    _info "Pushing $whl_name ..."
    lxc exec "$CONTAINER" -- mkdir -p "$CT_TMP_DIR"
    lxc file push "$wheel_path" "$CONTAINER$CT_TMP_DIR/$whl_name"

    # Prepare staging config: substitute real client_id if provided
    local conf_src="$STAGING_ROOT/container/photo-ingress.conf"
    local tmp_conf
    local existing_client_id=""
    tmp_conf="$(mktemp /tmp/photo-ingress-staging-XXXXXX.conf)"
    trap 'rm -f "${tmp_conf:-}"' EXIT
    cp "$conf_src" "$tmp_conf"

    existing_client_id="$(
        lxc exec "$CONTAINER" -- python3 -c "
from pathlib import Path

config_path = Path('$CONF_DEST')
placeholder = 'STAGING_CLIENT_ID_PLACEHOLDER'

if not config_path.exists():
    raise SystemExit(0)

for line in config_path.read_text(encoding='utf-8').splitlines():
    stripped = line.strip()
    if not stripped.startswith('client_id'):
        continue
    _, _, value = stripped.partition('=')
    client_id = value.strip()
    if client_id and client_id != placeholder:
        print(client_id)
    break
" 2>/dev/null || true
    )"

    if [[ -n "${STAGING_CLIENT_ID:-}" ]]; then
        sed -i "s/STAGING_CLIENT_ID_PLACEHOLDER/$STAGING_CLIENT_ID/" "$tmp_conf"
        if [[ -n "$existing_client_id" && "$existing_client_id" != "$STAGING_CLIENT_ID" ]]; then
            _warn "Existing STAGING_CLIENT_ID $existing_client_id in staging container overwritten with new ID: $STAGING_CLIENT_ID"
        fi
        _info "Substituted STAGING_CLIENT_ID."
    elif [[ -n "$existing_client_id" ]]; then
        sed -i "s/STAGING_CLIENT_ID_PLACEHOLDER/$existing_client_id/" "$tmp_conf"
        _info "Preserved the existing STAGING_CLIENT_ID in the container."
    else
        _warn "STAGING_CLIENT_ID not set — config retains placeholder. Auth will fail."
    fi

    lxc exec "$CONTAINER" -- mkdir -p /etc/nightfall
    lxc file push "$tmp_conf" "$CONTAINER$CONF_DEST"
    lxc exec "$CONTAINER" -- mkdir -p /var/lib/ingress/{staging,pending,accepted,rejected,trash,evidence,tokens,cursors,hashes}
    # Ensure runtime status path exists before starting hardened units.
    lxc exec "$CONTAINER" -- mkdir -p /run/nightfall-status.d
    # Ensure cache path exists for trash.service TemporaryFileSystem.
    lxc exec "$CONTAINER" -- mkdir -p /var/cache/nightfall-photo-ingress

    _info "Installing API + trash systemd units and staging overrides ..."
    lxc file push "$SYSTEMD_SOURCE_DIR/$API_SERVICE_NAME" \
        "$CONTAINER/etc/systemd/system/$API_SERVICE_NAME"
    lxc file push "$SYSTEMD_SOURCE_DIR/$TRASH_SERVICE_NAME" \
        "$CONTAINER/etc/systemd/system/$TRASH_SERVICE_NAME"
    lxc file push "$SYSTEMD_SOURCE_DIR/$TRASH_PATH_NAME" \
        "$CONTAINER/etc/systemd/system/$TRASH_PATH_NAME"

    lxc exec "$CONTAINER" -- mkdir -p \
        "/etc/systemd/system/$API_SERVICE_NAME.d" \
        "/etc/systemd/system/$SERVICE_NAME.service.d" \
        "/etc/systemd/system/$SERVICE_NAME.timer.d" \
        "/etc/systemd/system/$TRASH_SERVICE_NAME.d" \
        "/etc/systemd/system/$TRASH_PATH_NAME.d"

    if [[ -f "$STAGING_SYSTEMD_DIR/$API_SERVICE_NAME.d/override.conf" ]]; then
        lxc file push "$STAGING_SYSTEMD_DIR/$API_SERVICE_NAME.d/override.conf" \
            "$CONTAINER/etc/systemd/system/$API_SERVICE_NAME.d/override.conf"
    fi

    lxc file push "$STAGING_SYSTEMD_DIR/$SERVICE_NAME.service.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$SERVICE_NAME.service.d/override.conf"
    lxc file push "$STAGING_SYSTEMD_DIR/$SERVICE_NAME.timer.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$SERVICE_NAME.timer.d/override.conf"
    lxc file push "$STAGING_SYSTEMD_DIR/$TRASH_SERVICE_NAME.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$TRASH_SERVICE_NAME.d/override.conf"
    lxc file push "$STAGING_SYSTEMD_DIR/$TRASH_PATH_NAME.d/override.conf" \
        "$CONTAINER/etc/systemd/system/$TRASH_PATH_NAME.d/override.conf"

    lxc exec "$CONTAINER" -- systemctl daemon-reload

    # Remove legacy /run/user/* bind mounts from older staging containers.
    # These sources can disappear after host reboot/session changes and break
    # systemd service sandbox setup before ExecStart.
    lxc config device remove "$CONTAINER" tmpfs-tmp >/dev/null 2>&1 || true
    lxc config device remove "$CONTAINER" tmpfs-var-tmp >/dev/null 2>&1 || true
    lxc config device remove "$CONTAINER" tmpfs-nightfall-cache >/dev/null 2>&1 || true

    _info "Sanitizing known invalid distribution leftovers in staging venv ..."
    _sanitize_invalid_pillow_distribution

    _info "Running pip install (base + web extras) in container venv ..."
    lxc exec "$CONTAINER" -- \
        "$VENV_ROOT/bin/pip" install --quiet --upgrade --force-reinstall "$CT_TMP_DIR/$whl_name[web]"

    _info "Verifying staging venv has no invalid distribution warnings ..."
    _assert_no_invalid_distribution_warnings

    _info "Syncing API source tree to /opt/api ..."
    lxc exec "$CONTAINER" -- rm -rf /opt/api
    lxc file push --recursive "$PROJECT_ROOT/api" "$CONTAINER/opt/"

    if [[ -d "$WEB_BUILD_DIR" ]]; then
        _info "Syncing web build artifact to /opt/webui/build ..."
        lxc exec "$CONTAINER" -- rm -rf /opt/webui/build
        lxc exec "$CONTAINER" -- mkdir -p /opt/webui
        lxc file push --recursive "$WEB_BUILD_DIR" "$CONTAINER/opt/webui/"
    else
        _warn "Host web build artifact not found at $WEB_BUILD_DIR; leaving existing /opt/webui/build unchanged."
    fi

    # Push existing token cache if provided (DEPRECATED: use 'stagingctl auth-setup' instead)
    if [[ -n "${STAGING_TOKEN_JSON:-}" && -f "$STAGING_TOKEN_JSON" ]]; then
        _warn "DEPRECATED: STAGING_TOKEN_JSON will be removed in a future version."
        _warn "  Use 'stagingctl auth-setup' to authenticate interactively inside the container."
        _warn "  STAGING_TOKEN_JSON bypasses auth-setup and does not populate the identity"
        _warn "  sidecar (.identity.json) required by the OneDrive auth layer."
        _info "Pushing token cache $STAGING_TOKEN_JSON (deprecated path) ..."
        lxc file push "$STAGING_TOKEN_JSON" \
            "$CONTAINER/var/lib/ingress/tokens/staging.json"
    fi

    _info "Enabling systemd timer and trash path watcher ..."
    lxc exec "$CONTAINER" -- systemctl enable "$SERVICE_NAME.timer"
    lxc exec "$CONTAINER" -- systemctl enable "$TRASH_PATH_NAME"

    _info "Enabling and restarting API service ..."
    lxc exec "$CONTAINER" -- systemctl enable "$API_SERVICE_NAME"
    lxc exec "$CONTAINER" -- systemctl restart "$API_SERVICE_NAME"

    # Refresh reset baseline after install so `stagingctl reset` returns to
    # an installed, config-valid state with no onboarding token cache.
    lxc delete "$CONTAINER/$SNAPSHOT_CLEAN" 2>/dev/null || true
    _info "Taking LXD snapshot '$SNAPSHOT_CLEAN' (post-install baseline) ..."
    lxc snapshot "$CONTAINER" "$SNAPSHOT_CLEAN"

    _ok "Installed $whl_name. Timer/trash enabled and API service active. Snapshot '$SNAPSHOT_CLEAN' refreshed."
    _info "Run 'stagingctl smoke' to verify or 'stagingctl reset' to roll back."
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl uninstall
# ─────────────────────────────────────────────────────────────────────────────
cmd_uninstall() {
    local purge="0"
    if [[ "${1:-}" == "--purge" ]]; then
        purge="1"
    elif [[ -n "${1:-}" ]]; then
        _fail "Unknown uninstall option: ${1}. Did you mean --purge?"
    fi

    _info "Deleting container $CONTAINER ..."
    lxc delete --force "$CONTAINER" 2>/dev/null || true

    if [[ "$purge" == "1" ]]; then
        _info "Purging host evidence/log directories ..."
        rm -rf "$HOST_EVIDENCE_BASE" "$HOST_LOG_BASE"
        local tmpfs_host_base
        tmpfs_host_base="$(_resolve_tmpfs_host_base)"
        rm -rf "$tmpfs_host_base" 2>/dev/null || sudo -n rm -rf "$tmpfs_host_base" 2>/dev/null || true
           # In volatile mode, also clean up the now-empty parent under /run/
           if [[ "$STAGING_VOLATILE" == "1" ]]; then
               rmdir --ignore-fail-on-non-empty "$(dirname "$HOST_EVIDENCE_BASE")" 2>/dev/null || true
           fi
    fi

    _ok "Container deleted."
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl reset
# ─────────────────────────────────────────────────────────────────────────────
cmd_reset() {
    _require_container_exists

    _info "Stopping container ..."
    lxc stop "$CONTAINER" --force 2>/dev/null || true

    _info "Restoring LXD snapshot '$SNAPSHOT_CLEAN' ..."
    lxc restore "$CONTAINER" "$SNAPSHOT_CLEAN"

    _info "Starting container ..."
    lxc start "$CONTAINER"

    # Wait for readiness
    local i=0
    while ! lxc exec "$CONTAINER" -- systemctl is-system-running --quiet 2>/dev/null; do
        sleep 2; i=$((i + 2))
        [[ $i -lt 30 ]] || _warn "Container not fully ready after 30 s — continuing anyway."
        break
    done

    _ok "Container restored to '$SNAPSHOT_CLEAN'."
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl smoke
# ─────────────────────────────────────────────────────────────────────────────
cmd_smoke() {
    _require_container_running

    local run_id
    run_id="$(_gen_run_id)"
    local evidence_dir="$HOST_EVIDENCE_BASE/$run_id"
    mkdir -p "$evidence_dir"

    _info "Smoke run: $run_id"
    _info "Evidence : $evidence_dir"

    # ── manifest open ────────────────────────────────────────────────────────
    local manifest="$evidence_dir/manifest.jsonl"
    printf '{"event":"smoke_started","run_id":"%s","ts":"%s"}\n' \
        "$run_id" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$manifest"

    local rc=0

    # ── 1. cli check ─────────────────────────────────────────────────────────
    _info "Step 1/5: cli-help"
    lxc exec "$CONTAINER" -- \
        "$VENV_ROOT/bin/nightfall-photo-ingress" -h 2>&1 \
        | tee "$evidence_dir/cli-help.log" \
        && _assert_ok "$evidence_dir/assertions.jsonl" "cli_help_check" "exit 0" \
        || { _assert_fail "$evidence_dir/assertions.jsonl" "cli_help_check" "non-zero exit"; rc=1; }

    # ── 2. config-check ──────────────────────────────────────────────────────
    _info "Step 2/5: config-check + status export"
    lxc exec "$CONTAINER" -- \
        bash -lc "rm -f /run/nightfall-status.d/photo-ingress.json && \
        '$VENV_ROOT/bin/nightfall-photo-ingress' --log-mode json config-check --path '$CONF_DEST'" 2>&1 \
        | tee "$evidence_dir/config-check.log" \
        && _assert_ok "$evidence_dir/assertions.jsonl" "config_check" "valid config" \
        || { _assert_fail "$evidence_dir/assertions.jsonl" "config_check" "config invalid"; rc=1; }
    lxc exec "$CONTAINER" -- \
        python3 -c "import json, pathlib; payload=json.loads(pathlib.Path('/run/nightfall-status.d/photo-ingress.json').read_text()); assert payload['schema_version'] == 1; assert payload['service'] == 'photo-ingress'; assert payload['command'] == 'config-check'" \
        && _assert_ok "$evidence_dir/assertions.jsonl" "status_file_written" "config-check wrote status snapshot" \
        || { _assert_fail "$evidence_dir/assertions.jsonl" "status_file_written" "status snapshot missing or invalid"; rc=1; }

    # ── 3. trash processor smoke ──────────────────────────────────────────────
    _info "Step 3/5: trash processor"
    lxc exec "$CONTAINER" -- \
        systemctl start "$TRASH_SERVICE_NAME" 2>&1 \
        | tee "$evidence_dir/trash-service.log" \
        && _assert_ok "$evidence_dir/assertions.jsonl" "trash_service_start" "trash service completed" \
        || { _assert_fail "$evidence_dir/assertions.jsonl" "trash_service_start" "trash service failed"; rc=1; }

    # ── 4. optional live poll ─────────────────────────────────────────────────
    local account="${STAGING_ACCOUNT:-staging}"
    if [[ -n "${STAGING_CLIENT_ID:-}" ]]; then
        _info "Step 4/5: poll (account=$account)"
        lxc exec "$CONTAINER" -- \
            "$VENV_ROOT/bin/nightfall-photo-ingress" \
            --log-mode json poll --account "$account" --path "$CONF_DEST" 2>&1 \
            | tee "$evidence_dir/poll.log" \
            && _assert_ok "$evidence_dir/assertions.jsonl" "poll_exit_0" "poll completed" \
            || { _assert_fail "$evidence_dir/assertions.jsonl" "poll_exit_0" "poll failed"; rc=1; }
    else
        _warn "Step 4/5: poll SKIPPED (STAGING_CLIENT_ID not set)."
        printf '{"assertion":"poll_skipped","reason":"STAGING_CLIENT_ID_not_set","ts":"%s"}\n' \
            "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$evidence_dir/assertions.jsonl"
    fi

    # ── 5. secret scan ───────────────────────────────────────────────────────
    _info "Step 5/5: secret scan"
    lxc file push "$STAGING_ROOT/evidence/secret_scan.py" \
        "$CONTAINER$CT_TMP_DIR/staging_secret_scan.py"
    lxc exec "$CONTAINER" -- \
        "$VENV_ROOT/bin/python3" "$CT_TMP_DIR/staging_secret_scan.py" \
        "$CT_EVIDENCE_DIR/$run_id" 2>&1 \
        | tee "$evidence_dir/secret-scan.log" \
        && _assert_ok "$evidence_dir/assertions.jsonl" "secret_scan_clean" "no leaks" \
        || { _assert_fail "$evidence_dir/assertions.jsonl" "secret_scan_clean" "potential leaks found"; rc=1; }

    # ── manifest close ───────────────────────────────────────────────────────
    printf '{"event":"smoke_finished","run_id":"%s","ts":"%s","exit_code":%d}\n' \
        "$run_id" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$rc" >> "$manifest"

    if [[ $rc -eq 0 ]]; then
        _ok "Smoke PASSED — run_id=$run_id"
    else
        _fail "Smoke FAILED — run_id=$run_id  evidence: $evidence_dir"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl auth-setup
# ─────────────────────────────────────────────────────────────────────────────
cmd_auth_setup() {
    _require_container_running

    local account="${STAGING_ACCOUNT:-staging}"

    _info "Starting device-code auth for account '$account' ..."
    _info "A browser URL and one-time code will appear below."
    _info "Open the URL in a browser and complete sign-in to proceed."
    echo ""

    # -t allocates a PTY inside the container so MSAL output is unbuffered and
    # the device-code prompt displays correctly in the operator's terminal.
    lxc exec -t "$CONTAINER" -- \
        env NIGHTFALL_PROMPT_POLICY="${NIGHTFALL_PROMPT_POLICY:-}" \
        "$VENV_ROOT/bin/nightfall-photo-ingress" \
        auth-setup --account "$account" --path "$CONF_DEST" --skip-discovery

    echo ""
    _ok "auth-setup completed for account '$account'. Token cache written inside container."
    _info "Next step: run 'stagingctl discover-paths' to auto-discover storage paths."
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl discover-paths
# ─────────────────────────────────────────────────────────────────────────────
cmd_discover_paths() {
    _require_container_running

    local account="${STAGING_ACCOUNT:-staging}"

    _info "Auto-discovering OneDrive paths for account '$account' ..."
    echo ""

    lxc exec -t "$CONTAINER" -- \
        env NIGHTFALL_PROMPT_POLICY="${NIGHTFALL_PROMPT_POLICY:-}" \
        "$VENV_ROOT/bin/nightfall-photo-ingress" \
        discover-paths --account "$account" --path "$CONF_DEST"

    echo ""
    _ok "discover-paths completed for account '$account'."
    _info "Next step: run 'stagingctl smoke-live' to verify authenticated polling."
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl smoke-live
# ─────────────────────────────────────────────────────────────────────────────
cmd_smoke_live() {
    _require_container_running

    local run_id
    run_id="$(_gen_run_id)"
    local evidence_dir="$HOST_EVIDENCE_BASE/$run_id"
    mkdir -p "$evidence_dir"

    _info "Live smoke run: $run_id"
    _info "Evidence    : $evidence_dir"

    local manifest="$evidence_dir/manifest.jsonl"
    printf '{"event":"smoke_live_started","run_id":"%s","ts":"%s"}\n' \
        "$run_id" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$manifest"

    local rc=0
    local warning_count=0
    local account="${STAGING_ACCOUNT:-staging}"
    local token_path="/var/lib/ingress/tokens/${account}.json"
    local poll_log="$evidence_dir/poll-live.log"

    # ── 1. token cache present ────────────────────────────────────────────────
    _info "Step 1/3: token cache"
    if lxc exec "$CONTAINER" -- test -f "$token_path" 2>/dev/null; then
        _assert_ok "$evidence_dir/assertions.jsonl" "token_cache_exists" "$token_path present"
        _ok "Token cache found."
    else
        _assert_fail "$evidence_dir/assertions.jsonl" "token_cache_exists" \
            "$token_path missing — run: stagingctl auth-setup"
        _fail "No token cache. Run 'stagingctl auth-setup' first."
    fi

    # ── 2. live poll ──────────────────────────────────────────────────────────
    _info "Step 2/3: live poll (account=$account)"
    local poll_exit_code=0
    if [[ -t 1 ]] && command -v script >/dev/null 2>&1; then
        _info "Interactive terminal detected; using human-mode poll progress renderer."
        local poll_cmd
        printf -v poll_cmd 'lxc exec -t %q -- %q --log-mode human poll --verbose --account %q --path %q' \
            "$CONTAINER" "$VENV_ROOT/bin/nightfall-photo-ingress" "$account" "$CONF_DEST"
        script -qefc "$poll_cmd" "$poll_log" || poll_exit_code=$?
    else
        lxc exec "$CONTAINER" -- \
            "$VENV_ROOT/bin/nightfall-photo-ingress" \
            --log-mode json poll --account "$account" --path "$CONF_DEST" 2>&1 \
            | tee "$poll_log"
        poll_exit_code=${PIPESTATUS[0]}
    fi

    local runtime_limit_warning=0
    local drift_threshold_warning=0
    rg -q "Delta polling exceeded runtime limit|delta_runtime_limit_exceeded" "$poll_log" && runtime_limit_warning=1
    rg -q "Schema drift threshold exceeded|drift_threshold_critical" "$poll_log" && drift_threshold_warning=1

    if [[ $poll_exit_code -eq 0 ]]; then
        _assert_ok "$evidence_dir/assertions.jsonl" "live_poll_exit_0" "poll completed"
    elif [[ $runtime_limit_warning -eq 1 || $drift_threshold_warning -eq 1 ]]; then
        _assert_ok "$evidence_dir/assertions.jsonl" "live_poll_warning" "poll exited with warning-class condition (exit=$poll_exit_code)"
    else
        _assert_fail "$evidence_dir/assertions.jsonl" "live_poll_exit_0" "poll failed"
        rc=1
    fi

    if [[ $runtime_limit_warning -eq 1 ]]; then
        _assert_ok "$evidence_dir/assertions.jsonl" "live_poll_warning" "runtime limit reached during live poll"
        _warn "Live smoke completed with warning - polling took longer than configured staging timeout."
        warning_count=$((warning_count + 1))
    fi
    if [[ $drift_threshold_warning -eq 1 ]]; then
        _assert_ok "$evidence_dir/assertions.jsonl" "live_poll_warning" "schema drift threshold reached during live poll"
        _warn "Live smoke completed with warning - schema drift threshold reached (review drift summary for context)."
        warning_count=$((warning_count + 1))
    fi

    local traversal_summary=""
    traversal_summary="$(rg -n "traversal pages=" "$poll_log" | tail -n 1 | sed 's/^.*:trace /trace /' || true)"
    if [[ -n "$traversal_summary" ]]; then
        _info "Poll traversal summary: $traversal_summary"
    fi

    local latest_poll_detail_log=""
    latest_poll_detail_log="$(
        lxc exec "$CONTAINER" -- python3 - <<'PY' 2>/dev/null || true
from pathlib import Path

log_dir = Path('/var/lib/ingress/logs')
if not log_dir.exists():
    raise SystemExit(0)

candidates = sorted(log_dir.glob('poll-*.log'), key=lambda p: p.stat().st_mtime, reverse=True)
if candidates:
    print(str(candidates[0]))
PY
    )"
    if [[ -n "$latest_poll_detail_log" ]]; then
        if lxc file pull "$CONTAINER$latest_poll_detail_log" "$evidence_dir/poll-live-detailed.log" 2>/dev/null; then
            _info "Detailed poll trace saved to $evidence_dir/poll-live-detailed.log"
        fi
    fi

    # ── 3. secret scan ────────────────────────────────────────────────────────
    _info "Step 3/3: secret scan"
    lxc file push "$STAGING_ROOT/evidence/secret_scan.py" \
        "$CONTAINER$CT_TMP_DIR/staging_secret_scan.py"
    lxc exec "$CONTAINER" -- \
        "$VENV_ROOT/bin/python3" "$CT_TMP_DIR/staging_secret_scan.py" \
        "$CT_EVIDENCE_DIR/$run_id" 2>&1 \
        | tee "$evidence_dir/secret-scan.log" \
        && _assert_ok "$evidence_dir/assertions.jsonl" "secret_scan_clean" "no leaks" \
        || { _assert_fail "$evidence_dir/assertions.jsonl" "secret_scan_clean" "potential leaks found"; rc=1; }

    printf '{"event":"smoke_live_finished","run_id":"%s","ts":"%s","exit_code":%d,"warning_count":%d}\n' \
        "$run_id" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$rc" "$warning_count" >> "$manifest"

    if [[ $rc -eq 0 && $warning_count -gt 0 ]]; then
        _warn "Live smoke completed with warnings — run_id=$run_id  evidence: $evidence_dir"
    elif [[ $rc -eq 0 ]]; then
        _ok "Live smoke PASSED — run_id=$run_id"
    else
        _fail "Live smoke FAILED — run_id=$run_id  evidence: $evidence_dir"
    fi
}

# Write a passing assertion row to a JSONL audit file.
_assert_ok() {
    local audit_file="$1" name="$2" detail="$3"
    printf '{"assertion":"%s","result":"pass","detail":"%s","ts":"%s"}\n' \
        "$name" "$detail" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$audit_file"
}

# Write a failing assertion row to a JSONL audit file.
_assert_fail() {
    local audit_file="$1" name="$2" detail="$3"
    printf '{"assertion":"%s","result":"fail","detail":"%s","ts":"%s"}\n' \
        "$name" "$detail" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$audit_file"
}

# ─────────────────────────────────────────────────────────────────────────────
# stagingctl evidence [run-id]
# ─────────────────────────────────────────────────────────────────────────────
cmd_evidence() {
    local run_id="${1:-}"

    if [[ -z "$run_id" ]]; then
        _info "Evidence runs in $HOST_EVIDENCE_BASE:"
        if [[ -d "$HOST_EVIDENCE_BASE" ]]; then
            ls -1t "$HOST_EVIDENCE_BASE"
        else
            _info "(none — directory does not exist)"
        fi
        return 0
    fi

    local src="$HOST_EVIDENCE_BASE/$run_id"
    [[ -d "$src" ]] || _fail "No evidence directory for run: $run_id"

    _info "Files for run $run_id:"
    ls -lh "$src"

    if [[ -f "$src/assertions.jsonl" ]]; then
        _info "Assertions:"
        cat "$src/assertions.jsonl"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Dispatch
# ─────────────────────────────────────────────────────────────────────────────
_usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [args]

Commands:
    create              Create LXC container (profiles: default+staging) and baseline state.
    install [wheel]     Push wheel + config, enable service, and refresh 'clean' snapshot.
  uninstall [--purge] Delete container. --purge also removes host evidence/log directories.
  reset               Restore 'clean' snapshot and restart container.
  smoke               Run headless smoke assertions; collect evidence.
  auth-setup          Run interactive device-code auth for the staging account (requires TTY).
  discover-paths      Auto-discover OneDrive paths using cached token (no new login required).
  smoke-live          Run authenticated live poll + secret scan; collect evidence.
  evidence [id]       List or inspect evidence runs.

Environment variables:
  STAGING_CLIENT_ID       Azure client_id to inject into config.
  STAGING_ACCOUNT         Account section name (default: staging).
  STAGING_TOKEN_JSON      [DEPRECATED] Token cache path to push. Use 'auth-setup' instead.
  STAGING_VOLATILE        1 => use /run/staging-photo-ingress/{evidence,logs} (tmpfs).
                          0 => use /mnt/ssd/staging/photo-ingress/{evidence,logs} (default).
  STAGING_EVIDENCE_BASE   Override host-side evidence directory.
  STAGING_LOG_BASE        Override host-side log directory.
EOF
    exit 1
}

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        create)     cmd_create     "$@" ;;
        install)    cmd_install    "$@" ;;
        uninstall)  cmd_uninstall  "$@" ;;
        reset)      cmd_reset      "$@" ;;
        smoke)      cmd_smoke      "$@" ;;
        auth-setup)     cmd_auth_setup     "$@" ;;
        discover-paths) cmd_discover_paths  "$@" ;;
        smoke-live)     cmd_smoke_live      "$@" ;;
        evidence)   cmd_evidence   "$@" ;;
        *)          _usage ;;
    esac
}

main "$@"
