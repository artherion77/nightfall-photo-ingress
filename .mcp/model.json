{
  "version": "1.1",
  "metadata": {
    "name": "nightfall-photo-ingress-mcp-model",
    "description": "Canonical MCP task model for remote SSH workspace orchestration",
    "workspaceRoot": ".",
    "policy": "prefer_mcp_first",
    "hostInstallPolicy": "explicit_user_approval_required",
    "continuousExtensionPolicy": {
      "enabled": true,
      "trigger": "after_each_significant_task",
      "goal": "extend_mcp_and_connected_tools_when_extension_would_significantly_improve_efficiency",
      "capture": {
        "execFields": [
          "significantTask",
          "extensionRecommendation"
        ],
        "manualProposalEndpoint": "/mcp/extensions/propose",
        "backlogEndpoint": "/mcp/extensions"
      }
    },
    "design": {
      "cacheStrategy": "lxc_snapshot_reuse_plus_bind_mount_caches",
      "baseImageLayering": "documentation_only_future_option"
    },
    "execContract": {
      "optionalFields": [
        "args",
        "env",
        "cwd",
        "dependsOn",
        "significantTask",
        "extensionRecommendation"
      ],
      "dependsOn": "array of prior taskIds; task waits until all dependencies succeed",
      "statusTerminal": [
        "success",
        "failed"
      ],
      "statusLegacyTerminal": [
        "completed",
        "failed"
      ]
    },
    "configFiles": {
      "govctlManifest": "./dev/govctl-targets.yaml"
    }
  },
  "domains": {
    "backend": {
      "test.unit": [
        "./dev/bin/govctl run backend.test.unit --json"
      ],
      "test.integration": [
        "./dev/bin/govctl run backend.test.integration --json"
      ],
      "build": [
        "./dev/bin/govctl run backend.build.wheel --json"
      ],
      "deploy.dev": [
        "./dev/bin/govctl run backend.deploy.dev --json"
      ],
      "deploy.staging": [
        "./dev/bin/govctl run staging.install --json"
      ],
      "e2e": [
        "./dev/bin/govctl run backend.e2e --json"
      ]
    },
    "web": {
      "test.unit": [
        "./dev/bin/govctl run test.web --json"
      ],
      "test.integration": [
        "./dev/bin/govctl run web.test.integration --json"
      ],
      "build": [
        "./dev/bin/govctl run web.build --json"
      ],
      "deploy.dev": [
        "./dev/bin/govctl run web.deploy.dev --json"
      ],
      "deploy.staging": [
        "./dev/bin/govctl run staging.install --json"
      ],
      "e2e": [
        "./dev/bin/govctl run web.test.e2e --json"
      ]
    }
  },
  "devctl": {
    "path": "./dev/bin/devctl",
    "commands": [
      "setup",
      "destroy",
      "reset",
      "update",
      "check",
      "ensure-stack-ready",
      "assert-cached-ready",
      "run-api",
      "run-webui",
      "test-web-typecheck",
      "test-metrics-dashboard-typecheck",
      "test-web-unit",
      "test-web-e2e",
      "status",
      "shell"
    ],
    "scripts": {
      "build-metrics-dashboard": "./dev/bin/build-metrics-dashboard"
    },
    "cacheMounts": {
      "npm_home": "~/.npm -> /root/.npm",
      "npm_cache": "~/.cache/npm -> /root/.cache/npm",
      "pip_cache": "~/.cache/pip -> /root/.cache/pip"
    }
  },
  "govctl": {
    "path": "./dev/bin/govctl",
    "manifest": "./dev/govctl-targets.yaml",
    "commands": [
      "list",
      "check",
      "graph",
      "run"
    ],
    "jsonMode": "--json"
  },
  "stagectl": {
    "path": "./dev/bin/stagingctl",
    "commands": [
      "create",
      "install",
      "uninstall",
      "reset",
      "smoke",
      "auth-setup",
      "discover-paths",
      "smoke-live",
      "evidence"
    ]
  },
  "devcontainer": {
    "prepare": [
      "./dev/bin/govctl run devcontainer.prepare --json"
    ],
    "reset": [
      "./dev/bin/govctl run devcontainer.reset --json"
    ]
  },
  "staging": {
    "urls": {
      "api": "https://staging.example.invalid/api",
      "web": "https://staging.example.invalid"
    },
    "access": {
      "method": "token_or_ssh",
      "tokenEnv": "STAGING_TOKEN_PLACEHOLDER",
      "ssh": "ssh user@staging-host"
    }
  },
  "mappings": {
    "devcontainer.prepare": [
      "./dev/bin/govctl run devcontainer.prepare --json"
    ],
    "devcontainer.check": [
      "./dev/bin/govctl run devcontainer.check --json"
    ],
    "devcontainer.update": [
      "./dev/bin/govctl run devcontainer.update --json"
    ],
    "devcontainer.reset": [
      "./dev/bin/govctl run devcontainer.reset --json"
    ],
    "backend.test.unit": [
      "./dev/bin/govctl run backend.test.unit --json"
    ],
    "backend.test.unit.direct": [
      "./dev/bin/govctl run backend.test.unit --json"
    ],
    "backend.test.integration": [
      "./dev/bin/govctl run backend.test.integration --json"
    ],
    "web.test.unit": [
      "./dev/bin/govctl run web.test.unit --json"
    ],
    "web.test.unit.direct": [
      "./dev/bin/govctl run test.web --json"
    ],
    "web.test.integration": [
      "./dev/bin/govctl run web.test.integration --json"
    ],
    "web.test.e2e": [
      "./dev/bin/govctl run web.test.e2e --json"
    ],
    "mcp.smoke.success": [
      "echo '[mcp.smoke.success] ok'"
    ],
    "mcp.smoke.fail": [
      "echo '[mcp.smoke.fail] intentional failure' && false"
    ],
    "metrics.status": [
      "./dev/bin/govctl run metrics.status --json"
    ],
    "metrics.run-now": [
      "./dev/bin/govctl run metrics.run-now --json"
    ],
    "metrics.publish": [
      "./dev/bin/govctl run metrics.publish --json"
    ],
    "metrics.build-dashboard": [
      "./dev/bin/govctl run metrics.build.dashboard --json"
    ],
    "metrics.install": [
      "./dev/bin/govctl run metrics.install --json"
    ],
    "metrics.stop": [
      "./dev/bin/govctl run metrics.stop --json"
    ],
    "web.e2e": [
      "./dev/bin/govctl run web.test.e2e --json"
    ]
  },
  "verifications": {
    "unit": {
      "backend": [
        "./dev/bin/govctl run backend.test.unit --json"
      ],
      "web": [
        "./dev/bin/govctl run test.web --json"
      ]
    },
    "integration": {
      "backend": [
        "./dev/bin/govctl run backend.test.integration --json"
      ],
      "web": [
        "./dev/bin/govctl run web.test.integration --json"
      ]
    },
    "e2e": {
      "backend": [
        "./dev/bin/govctl run backend.e2e --json"
      ],
      "web": [
        "./dev/bin/govctl run web.test.e2e --json"
      ]
    }
  }
}
