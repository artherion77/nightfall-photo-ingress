{
  "version": "1.1",
  "metadata": {
    "name": "nightfall-photo-ingress-mcp-model",
    "description": "Canonical MCP task model for remote SSH workspace orchestration",
    "workspaceRoot": ".",
    "policy": "prefer_mcp_first",
    "hostInstallPolicy": "explicit_user_approval_required",
    "continuousExtensionPolicy": {
      "enabled": true,
      "trigger": "after_each_significant_task",
      "goal": "extend_mcp_and_connected_tools_when_extension_would_significantly_improve_efficiency",
      "capture": {
        "execFields": [
          "significantTask",
          "extensionRecommendation"
        ],
        "manualProposalEndpoint": "/mcp/extensions/propose",
        "backlogEndpoint": "/mcp/extensions"
      }
    },
    "design": {
      "cacheStrategy": "lxc_snapshot_reuse_plus_bind_mount_caches",
      "baseImageLayering": "documentation_only_future_option"
    },
    "execContract": {
      "optionalFields": [
        "args",
        "env",
        "cwd",
        "dependsOn",
        "significantTask",
        "extensionRecommendation"
      ],
      "dependsOn": "array of prior taskIds; task waits until all dependencies succeed",
      "statusTerminal": [
        "success",
        "failed"
      ],
      "statusLegacyTerminal": [
        "completed",
        "failed"
      ]
    }
  },
  "domains": {
    "backend": {
      "test.unit": [
        "./dev/devctl setup",
        "./dev/devctl assert-cached-ready",
        "./dev/devctl reset",
        "./.venv/bin/python -m pytest tests/unit"
      ],
      "test.integration": [
        "./dev/devctl setup",
        "./dev/devctl assert-cached-ready",
        "./dev/devctl reset",
        "./.venv/bin/python -m pytest tests/integration"
      ],
      "build": [
        "python -m build"
      ],
      "deploy.dev": [
        "./dev/devctl setup",
        "./dev/devctl run-api"
      ],
      "deploy.staging": [
        "./staging/stagingctl install"
      ],
      "e2e": [
        "./staging/stagingctl smoke"
      ]
    },
    "web": {
      "test.unit": [
        "./dev/devctl setup",
        "./dev/devctl assert-cached-ready",
        "./dev/devctl reset",
        "./dev/devctl test-web-typecheck",
        "./dev/devctl test-metrics-dashboard-typecheck",
        "./dev/devctl test-web-unit"
      ],
      "test.integration": [
        "./dev/devctl test-web-e2e"
      ],
      "build": [
        "npm --prefix webui run build"
      ],
      "deploy.dev": [
        "./dev/devctl setup",
        "./dev/devctl run-webui"
      ],
      "deploy.staging": [
        "./dev/devctl setup"
      ],
      "e2e": [
        "./dev/devctl test-web-e2e"
      ]
    }
  },
  "devctl": {
    "path": "./dev/devctl",
    "commands": [
      "setup",
      "create",
      "destroy",
      "bootstrap-python",
      "bootstrap-webui",
      "bootstrap-playwright",
      "ensure-stack-ready",
      "snapshot-create",
      "snapshot-refresh",
      "reset",
      "assert-cached-ready",
      "run-api",
      "run-webui",
      "test-web-typecheck",
      "test-metrics-dashboard-typecheck",
      "test-web-unit",
      "test-web-e2e",
      "status",
      "shell"
    ],
    "cacheMounts": {
      "npm_home": "~/.npm -> /root/.npm",
      "npm_cache": "~/.cache/npm -> /root/.cache/npm",
      "pip_cache": "~/.cache/pip -> /root/.cache/pip",
      "playwright_cache": "~/.cache/ms-playwright -> /root/.cache/ms-playwright"
    }
  },
  "stagectl": {
    "path": "./staging/stagingctl",
    "commands": [
      "create",
      "install",
      "uninstall",
      "reset",
      "smoke",
      "auth-setup",
      "discover-paths",
      "smoke-live",
      "evidence"
    ]
  },
  "devcontainer": {
    "prepare": [
      "./dev/devctl setup",
      "./dev/devctl assert-cached-ready",
      "./dev/devctl status"
    ],
    "reset": [
      "./dev/devctl reset",
      "./dev/devctl assert-cached-ready",
      "./dev/devctl status"
    ]
  },
  "staging": {
    "urls": {
      "api": "https://staging.example.invalid/api",
      "web": "https://staging.example.invalid"
    },
    "access": {
      "method": "token_or_ssh",
      "tokenEnv": "STAGING_TOKEN_PLACEHOLDER",
      "ssh": "ssh user@staging-host"
    }
  },
  "mappings": {
    "devcontainer.prepare": [
      "./dev/devctl setup",
      "./dev/devctl assert-cached-ready",
      "./dev/devctl status"
    ],
    "devcontainer.reset": [
      "./dev/devctl reset",
      "./dev/devctl assert-cached-ready",
      "./dev/devctl status"
    ],
    "backend.test.unit": [
      "./dev/devctl setup",
      "./dev/devctl assert-cached-ready",
      "./dev/devctl reset",
      "./.venv/bin/python -m pytest tests/unit"
    ],
    "backend.test.integration": [
      "./dev/devctl setup",
      "./dev/devctl assert-cached-ready",
      "./dev/devctl reset",
      "./.venv/bin/python -m pytest tests/integration"
    ],
    "web.test.unit": [
      "./dev/devctl setup",
      "./dev/devctl assert-cached-ready",
      "./dev/devctl reset",
      "./dev/devctl test-web-typecheck",
      "./dev/devctl test-metrics-dashboard-typecheck",
      "./dev/devctl test-web-unit"
    ],
    "web.test.integration": [
      "./dev/devctl test-web-e2e"
    ],
    "web.test.e2e": [
      "./dev/devctl test-web-e2e"
    ],
    "mcp.smoke.success": [
      "echo '[mcp.smoke.success] ok'"
    ],
    "mcp.smoke.fail": [
      "echo '[mcp.smoke.fail] intentional failure' && false"
    ],
    "metrics.status": [
      "./metricsctl status"
    ],
    "metrics.run-now": [
      "./metricsctl run-now"
    ],
    "metrics.publish": [
      "./metricsctl publish"
    ],
    "metrics.install": [
      "./metricsctl install"
    ],
    "metrics.stop": [
      "./metricsctl stop"
    ],
    "web.e2e": [
      "./staging/stagingctl smoke"
    ]
  },
  "verifications": {
    "unit": {
      "backend": [
        "./dev/devctl setup",
        "./dev/devctl assert-cached-ready",
        "./dev/devctl reset",
        "./.venv/bin/python -m pytest tests/unit"
      ],
      "web": [
        "./dev/devctl setup",
        "./dev/devctl assert-cached-ready",
        "./dev/devctl reset",
        "./dev/devctl test-web-typecheck",
        "./dev/devctl test-metrics-dashboard-typecheck",
        "./dev/devctl test-web-unit"
      ]
    },
    "integration": {
      "backend": [
        "./dev/devctl setup",
        "./dev/devctl assert-cached-ready",
        "./dev/devctl reset",
        "./.venv/bin/python -m pytest tests/integration"
      ],
      "web": [
        "./dev/devctl test-web-e2e"
      ]
    },
    "e2e": {
      "backend": [
        "./staging/stagingctl smoke"
      ],
      "web": [
        "./dev/devctl test-web-e2e"
      ]
    }
  }
}
