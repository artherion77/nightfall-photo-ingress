[Unit]
Description=Nightfall Photo Ingress API (FastAPI/Uvicorn)
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt
Environment=PATH=/opt/ingress/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/bin/env uvicorn api.app:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
